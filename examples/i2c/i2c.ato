import Addressor
import I2C
import ElectricPower

from "atopile/microchip-mcp9808/microchip-mcp9808.ato" import Microchip_MCP9808

module App:
    """
    Automatic I2C address configuration example.

    Package automatically configures I2C address pins for specified address.
    """

    # I2C package
    temp_sensor = new Microchip_MCP9808 # base address 0x18 (A2=LOW, A1=LOW, A0=LOW)

    # Reference interfaces
    power = new ElectricPower
    power ~ temp_sensor.power

    i2c_bus = new I2C
    i2c_bus ~ temp_sensor.i2c

    # Option 1: set I2C address directly (within limits of device, 0x18 - 0x1F)
    temp_sensor.i2c.address = 0x1A

    # Option 2: set I2C address offset relative to base address (0x18)
    temp_sensor.addressor.offset = 0x2 # (0x18 + 0x2) = 0x1A
