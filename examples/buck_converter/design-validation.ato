    req_p02.max_val = 0.05
    req_p02.typical = 0.025
    req_p02.context_nets = "dut.package.SW,i(l1)"
    req_p02.justification = "DS Eq.31-33: output ripple <50mV at VIN=48V worst case."

    # =================================================================
    # E — EFFICIENCY VS LOAD
    # =================================================================
    # Measures η = Pout/Pin at each load current across input voltages.
    # DS Figure 11-14: efficiency curves at various VIN.
    # Requirement: η > 70% across 0.5-5A (proof of concept bounds).

    eff_vin12 = new SimulationSweep
    eff_vin12.param_name = "ILOAD"
    eff_vin12.param_values = "0.5,1,2,3,4,5"
