#pragma experiment("BRIDGE_CONNECT")

import SimulationTransient
import SimulationSweep
import Requirement
import Resistor
from "buck_converter.ato" import TI_TPS54560

# =============================================================================
# Design Validation — Multi-DUT Operating-Point Verification
#
# Three DUT instances of TI_TPS54560, each constrained to different operating
# conditions. Simulations and requirements are defined ONCE with `dut.` prefix
# references and automatically evaluated against each DUT.
#
# `dut.power_in.hv` → resolves to net name per DUT (e.g., dut12_power_in_hv)
# `dut.power_in.voltage` → resolves to parameter value per DUT (e.g., 12.0)
#
# SPICE netlist element map (per DUT scope — verify with circuit.spice):
#   V1-V5 = constraint-injected voltage sources (removed by all simulations)
#   R1 = r_top (FB divider, solver-computed)
#   R2 = r_bottom (FB divider, 10.2k)
#   R3 = r_comp (16.9k), R4 = r_en (442k), R5 = r_en_bot (90.9k)
#   R6 = r_rt (243k), R7 = r_load (1ohm)
#   C1 = c_boot, C2 = c_comp, C3 = c_comp1, C4 = c_in
#   C_OUT[1-3] = output caps (added via extra_spice)
#   L1 = inductor (6.8u), X1 = TPS54560_TRANS
# =============================================================================


# Test bench wrapper: TI_TPS54560 + load resistor in same scope
module TPS54560_DV from TI_TPS54560:
    """DUT wrapper with default load resistor."""
    r_load = new Resistor
    r_load.resistance = 1ohm +/- 5%
    r_load.package = "1210"
    power_out.hv ~> r_load ~> power_out.lv


module DesignValidation:
    """Design validation with multiple operating points under one build target."""

    # --- DUT Instances ---
    dut12 = new TPS54560_DV
    dut12.r_top.resistance = 53.6kohm +/- 1%
    assert dut12.power_out.voltage within 5V +/- 5%
    assert dut12.power_in.voltage within 12V +/- 5%

    dut24 = new TPS54560_DV
    dut24.r_top.resistance = 53.6kohm +/- 1%
    assert dut24.power_out.voltage within 5V +/- 5%
    assert dut24.power_in.voltage within 24V +/- 5%

    dut48 = new TPS54560_DV
    dut48.r_top.resistance = 53.6kohm +/- 1%
    assert dut48.power_out.voltage within 5V +/- 5%
    assert dut48.power_in.voltage within 48V +/- 5%

    # --- Startup Transient (shared across all DUTs) ---
    startup_transient = new SimulationTransient
    startup_transient.duts = "dut12,dut24,dut48"
    startup_transient.spice = "V1 dut.power_in.hv 0 PULSE(0 dut.power_in.voltage 0 10u 10u 10 10)"
    startup_transient.time_stop = 15ms
    startup_transient.time_step = 1us
    startup_transient.remove_elements = "X1,V2,V3,V4,V5"
    startup_transient.extra_spice = "X1 dut.package.boot dut.package.comp dut.package.en 0 dut.package.sw dut.package.rt_clk dut.power_in.hv dut.package.fb TPS54560_TRANS FS=400k|C_OUT1 dut.power_out.hv 0 47u|C_OUT2 dut.power_out.hv 0 47u|C_OUT3 dut.power_out.hv 0 47u"

    req_001 = new Requirement
    req_001.req_name = "REQ_001: Startup Settling Time"
    req_001.simulation = "startup_transient"
    req_001.net = "dut.power_out.hv"
    req_001.capture = "transient"
    req_001.measurement = "settling_time"
    req_001.min_val = "0"
    req_001.max_val = "0.005"
    req_001.context_nets = "dut.power_in.hv"
    req_001.plot.title = "Output Voltage Startup"
    req_001.plot.nets = "dut.power_out.hv,dut.power_in.hv"
