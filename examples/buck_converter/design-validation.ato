    # NOTE: Efficiency pass/fail requirements are omitted because the
    # behavioral switch model (S_hs with Ron/Roff) cannot accurately model
    # input current, especially at high step-down ratios.  At light loads
    # the measured i(V1) is too low (η > 100%) and at heavy loads with
    # high VIN it is too high (η < 50%).  The overlay chart below still
    # provides a visual reference.  Accurate efficiency validation requires
    # a transistor-level MOSFET model or an analytical loss budget.

    # =================================================================
    # OVERLAY CHARTS — combined views
    # =================================================================

    chart_efficiency = new SweepOverlayChart
    chart_efficiency.title = "Efficiency vs Load Current"
