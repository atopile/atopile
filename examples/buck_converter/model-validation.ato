#pragma experiment("BRIDGE_CONNECT")

import SimulationTransient
import SimulationSweep
import LineChart
import BarChart
import Requirement

from "buck_converter.ato" import TPS54560_Reference

# =============================================================================
# TPS54560 Model Validation
# Datasheet: SLVSBN0C (March 2013, Rev March 2017)
# Section 8.2.3 — Application Curves (Figures 34–55)
#
# DUT: 5V/5A output, 12V nominal input, 400kHz switching (DS Figure 33)
#
# Netlist element map (from ato build):
#   R1=r_bottom(10.2k) R2=r_comp(16.9k) R3=r_en(442k) R4=r_en_bot(90.9k)
#   R5=r_load(1k) R6=r_rt(243k) R7=r_top(53.6k)
#   C1=c_boot(100n) C2=c_comp(4.7n) C3=c_comp1(47p) C4=c_in(10u)
#   C5-C8=c_out(4x47u) — NOTE: MultiCapacitor values don't resolve in SPICE,
#   so output caps are manually added via extra_spice on each simulation.
#   L1=inductor(6.8u)  X1=TPS54560_TRANS(FS=param_bindings)
# =============================================================================

module ModelValidation:
    "TPS54560 model validation — DS Section 8.2.3 Application Curves."

    dut = new TPS54560_Reference
    assert dut.power_out.voltage within 5V +/- 5%
    assert dut.power_in.voltage within 12V +/- 5%
    assert dut.switching_frequency within 400kHz +/- 5%
    dut.power_out.max_current = 5A

    # =================================================================
    # MV_001: Start-up With EN — Vout regulation (DS Fig 37)
    # EN-controlled startup: VIN=12V steady, EN pulse at 2ms
    # =================================================================
    sim_001 = new SimulationTransient
    sim_001.duts = "dut"
    sim_001.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_001.remove_elements = "R4"
    sim_001.extra_spice = "V_EN dut.enable.line 0 PULSE(0 12 2e-3 10u 10u 10 10)|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_001.time_stop = 20ms
    sim_001.time_step = 1us

    plot_001 = new LineChart
    plot_001.title = "Start-up With EN (DS Fig 37)"
    plot_001.x = "time"
    plot_001.y = "dut.power_out.hv"
    plot_001.y_secondary = "i(l1)"
    plot_001.simulation = "sim_001"

    req_001 = new Requirement
    req_001.req_name = "MV_001: [Fig 37] Start-up With EN — Vout regulation"
    req_001.simulation = "sim_001"
    req_001.net = "dut.power_out.hv"
    req_001.measurement = "final_value"
    assert req_001.limit within 4.75V to 5.25V
    req_001.justification = "DS Fig 37: EN-controlled startup must reach 5V regulation."
    req_001.required_plot = "plot_001"

    # =================================================================
    # MV_002: Load Transient — Vout perturbation (DS Fig 34)
    # Load step sweep: ILOAD = 1A to 5A, pulse from 0.25mA
    # =================================================================
    sim_002 = new SimulationSweep
    sim_002.duts = "dut"
    sim_002.param_name = "ILOAD"
    sim_002.param_values = "1,2,3,4,5"
    sim_002.param_unit = "A"
    sim_002.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_002.remove_elements = "R5"
    sim_002.extra_spice_template = "I_LOAD dut.power_out.hv 0 PULSE(100m {ILOAD} 7m 1u 1u 5m 20m)|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_002.time_start = 5ms
    sim_002.time_stop = 15ms
    sim_002.time_step = 100ns

    plot_002_vout = new LineChart
    plot_002_vout.title = "Load Transient Response (DS Fig 34)"
    plot_002_vout.x = "time"
    plot_002_vout.y = "ac_coupled(dut.power_out.hv)"
    plot_002_vout.y_secondary = "i(l1)"
    plot_002_vout.color = "ILOAD"
    plot_002_vout.simulation = "sim_002"

    plot_002_bar = new BarChart
    plot_002_bar.title = "Peak-to-Peak vs Load Current"
    plot_002_bar.x = "ILOAD"
    plot_002_bar.y = "peak_to_peak(dut.power_out.hv)"
    plot_002_bar.simulation = "sim_002"

    req_002 = new Requirement
    req_002.req_name = "MV_002: [Fig 34] Load Transient — Vout perturbation"
    req_002.simulation = "sim_002"
    req_002.net = "dut.power_out.hv"
    req_002.measurement = "peak_to_peak"
    assert req_002.limit within 0V to 600mV
    req_002.justification = "DS Fig 34: Load transient <600mV for 5A step (4x47uF output)."
    req_002.required_plot = "plot_002_bar"
    req_002.supplementary_plot = "plot_002_vout"

    # =================================================================
    # MV_003: Line Transient — Vout perturbation (DS Fig 35)
    # VIN step 8V to 40V at 15ms
    # =================================================================
    sim_003 = new SimulationTransient
    sim_003.duts = "dut"
    sim_003.spice = "V1 dut.power_in.hv 0 PULSE(8 40 15e-3 1u 1u 5e-3 20e-3)"
    sim_003.extra_spice = "Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_003.time_start = 8ms
    sim_003.time_stop = 30ms
    sim_003.time_step = 1us

    plot_003 = new LineChart
    plot_003.title = "Line Transient Response (DS Fig 35)"
    plot_003.x = "time"
    plot_003.y = "ac_coupled(dut.power_out.hv)"
    plot_003.y_secondary = "dut.power_in.hv"
    plot_003.simulation = "sim_003"

    req_003 = new Requirement
    req_003.req_name = "MV_003: [Fig 35] Line Transient — Vout perturbation"
    req_003.simulation = "sim_003"
    req_003.net = "dut.power_out.hv"
    req_003.measurement = "peak_to_peak"
    assert req_003.limit within 0V to 300mV
    req_003.justification = "DS Fig 35: Line transient 8V-40V, Vout perturbation <300mV."
    req_003.required_plot = "plot_003"

    # =================================================================
    # MV_004: Output Ripple CCM — Vout ripple (DS Fig 38)
    # 5A CCM load, VIN=12V, measure Vout peak-to-peak
    # =================================================================
    sim_004 = new SimulationTransient
    sim_004.duts = "dut"
    sim_004.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_004.remove_elements = "R5"
    sim_004.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_004.time_start = 10ms
    sim_004.time_stop = 10.1ms
    sim_004.time_step = 25ns

    plot_004 = new LineChart
    plot_004.title = "Output Ripple CCM — Vout (DS Fig 38)"
    plot_004.x = "time"
    plot_004.y = "ac_coupled(dut.power_out.hv)"
    plot_004.y_secondary = "i(l1)"
    plot_004.simulation = "sim_004"

    req_004 = new Requirement
    req_004.req_name = "MV_004: [Fig 38] Output Ripple CCM — Vout ripple"
    req_004.simulation = "sim_004"
    req_004.net = "dut.power_out.hv"
    req_004.measurement = "peak_to_peak"
    assert req_004.limit within 0V to 25mV
    req_004.justification = "DS Table 1: Output ripple < 0.5% of Vout (25mV). DS Fig 38 ~15mV."
    req_004.required_plot = "plot_004"

    # =================================================================
    # MV_005: Output Ripple CCM — Switching frequency (DS Fig 38)
    # Same circuit as MV_004, measure SW node frequency
    # =================================================================
    sim_005 = new SimulationTransient
    sim_005.duts = "dut"
    sim_005.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_005.remove_elements = "R5"
    sim_005.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_005.time_start = 10ms
    sim_005.time_stop = 10.1ms
    sim_005.time_step = 25ns

    plot_005 = new LineChart
    plot_005.title = "SW Node — Switching Frequency (DS Fig 38)"
    plot_005.x = "time"
    plot_005.y = "dut.package.SW"
    plot_005.simulation = "sim_005"

    req_005 = new Requirement
    req_005.req_name = "MV_005: [Fig 38] Output Ripple CCM — Switching frequency"
    req_005.simulation = "sim_005"
    req_005.net = "dut.package.SW"
    req_005.measurement = "frequency"
    assert req_005.limit within 360kHz to 440kHz
    req_005.justification = "DS: fsw=400kHz +/-10%. Validates FS parameter."
    req_005.required_plot = "plot_005"

    # =================================================================
    # MV_006: Output Ripple CCM — Inductor current avg (DS Fig 38)
    # Same circuit, measure average inductor current
    # =================================================================
    sim_006 = new SimulationTransient
    sim_006.duts = "dut"
    sim_006.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_006.remove_elements = "R5"
    sim_006.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_006.time_start = 10ms
    sim_006.time_stop = 10.1ms
    sim_006.time_step = 25ns

    plot_006 = new LineChart
    plot_006.title = "Inductor Current — Average (DS Fig 38)"
    plot_006.x = "time"
    plot_006.y = "i(l1)"
    plot_006.simulation = "sim_006"

    req_006 = new Requirement
    req_006.req_name = "MV_006: [Fig 38] Output Ripple CCM — Inductor current avg"
    req_006.simulation = "sim_006"
    req_006.net = "i(l1)"
    req_006.measurement = "average"
    assert req_006.limit within 4A to 6A
    req_006.justification = "IL_avg = Iout = Vout/Rload = 5V/1ohm = 5A."
    req_006.required_plot = "plot_006"

    # =================================================================
    # MV_007: Output Ripple CCM — Inductor ripple (DS Fig 38)
    # Same circuit, measure inductor current peak-to-peak
    # =================================================================
    sim_007 = new SimulationTransient
    sim_007.duts = "dut"
    sim_007.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_007.remove_elements = "R5"
    sim_007.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_007.time_start = 10ms
    sim_007.time_stop = 10.1ms
    sim_007.time_step = 25ns

    plot_007 = new LineChart
    plot_007.title = "Inductor Current — Ripple (DS Fig 38)"
    plot_007.x = "time"
    plot_007.y = "i(l1)"
    plot_007.simulation = "sim_007"

    req_007 = new Requirement
    req_007.req_name = "MV_007: [Fig 38] Output Ripple CCM — Inductor ripple"
    req_007.simulation = "sim_007"
    req_007.net = "i(l1)"
    req_007.measurement = "peak_to_peak"
    assert req_007.limit within 500mA to 3A
    req_007.justification = "DS Eq.28: IL_pp = (VIN-VOUT)*D/(fsw*L) = (12-5)*0.42/(400k*6.8u) ~ 1.08A."
    req_007.required_plot = "plot_007"

    # =================================================================
    # MV_008: Output Ripple DCM — Vout ripple (DS Fig 39)
    # DCM: IOUT=100mA via R=50ohm (5V/50=100mA)
    # =================================================================
    sim_008 = new SimulationTransient
    sim_008.duts = "dut"
    sim_008.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_008.remove_elements = "R5"
    sim_008.extra_spice = "R_LOAD_DCM dut.power_out.hv 0 50|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_008.time_start = 20ms
    sim_008.time_stop = 20.1ms
    sim_008.time_step = 25ns

    plot_008 = new LineChart
    plot_008.title = "Output Ripple DCM (DS Fig 39)"
    plot_008.x = "time"
    plot_008.y = "ac_coupled(dut.power_out.hv)"
    plot_008.y_secondary = "i(l1)"
    plot_008.simulation = "sim_008"

    req_008 = new Requirement
    req_008.req_name = "MV_008: [Fig 39] Output Ripple DCM — Vout ripple"
    req_008.simulation = "sim_008"
    req_008.net = "dut.power_out.hv"
    req_008.measurement = "peak_to_peak"
    assert req_008.limit within 0V to 150mV
    req_008.justification = "DS Fig 39: DCM ripple at 100mA load (50 ohm)."
    req_008.required_plot = "plot_008"

    # =================================================================
    # MV_009: Output Ripple PSM — Vout ripple (DS Fig 40)
    # Eco-mode / PSM: no load, 100k dummy resistor
    # =================================================================
    sim_009 = new SimulationTransient
    sim_009.duts = "dut"
    sim_009.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_009.remove_elements = "R5"
    sim_009.extra_spice = "R_LOAD_PSM dut.power_out.hv 0 100k|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_009.time_start = 10ms
    sim_009.time_stop = 20ms
    sim_009.time_step = 100ns

    plot_009 = new LineChart
    plot_009.title = "Output Ripple PSM / Eco-mode (DS Fig 40)"
    plot_009.x = "time"
    plot_009.y = "ac_coupled(dut.power_out.hv)"
    plot_009.y_secondary = "i(l1)"
    plot_009.simulation = "sim_009"

    req_009 = new Requirement
    req_009.req_name = "MV_009: [Fig 40] Output Ripple PSM — Vout ripple"
    req_009.simulation = "sim_009"
    req_009.net = "dut.power_out.hv"
    req_009.measurement = "peak_to_peak"
    assert req_009.limit within 0V to 100mV
    req_009.justification = "DS Fig 40: Eco-mode (no load) ripple. Pulse-skipping increases ripple."
    req_009.required_plot = "plot_009"

    # =================================================================
    # MV_010: Input Ripple CCM (DS Fig 41)
    # 5A CCM load, measure VIN ripple
    # Note: Ideal V source → VIN ripple = 0. Kept for completeness.
    # =================================================================
    sim_010 = new SimulationTransient
    sim_010.duts = "dut"
    sim_010.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_010.remove_elements = "R5"
    sim_010.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_010.time_start = 10ms
    sim_010.time_stop = 10.1ms
    sim_010.time_step = 25ns

    plot_010 = new LineChart
    plot_010.title = "Input Ripple CCM (DS Fig 41)"
    plot_010.x = "time"
    plot_010.y = "ac_coupled(dut.power_in.hv)"
    plot_010.y_secondary = "i(l1)"
    plot_010.simulation = "sim_010"

    req_010 = new Requirement
    req_010.req_name = "MV_010: [Fig 41] Input Ripple CCM — VIN ripple"
    req_010.simulation = "sim_010"
    req_010.net = "dut.power_in.hv"
    req_010.measurement = "peak_to_peak"
    assert req_010.limit within 0V to 200mV
    req_010.justification = "DS Fig 41: Input voltage ripple at 5A CCM load."
    req_010.required_plot = "plot_010"

    # =================================================================
    # MV_011: Input Ripple DCM (DS Fig 42)
    # DCM: 100mA via R=50ohm, measure VIN ripple
    # =================================================================
    sim_011 = new SimulationTransient
    sim_011.duts = "dut"
    sim_011.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_011.remove_elements = "R5"
    sim_011.extra_spice = "R_LOAD_DCM dut.power_out.hv 0 50|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_011.time_start = 20ms
    sim_011.time_stop = 20.1ms
    sim_011.time_step = 25ns

    plot_011 = new LineChart
    plot_011.title = "Input Ripple DCM (DS Fig 42)"
    plot_011.x = "time"
    plot_011.y = "ac_coupled(dut.power_in.hv)"
    plot_011.y_secondary = "i(l1)"
    plot_011.simulation = "sim_011"

    req_011 = new Requirement
    req_011.req_name = "MV_011: [Fig 42] Input Ripple DCM — VIN ripple"
    req_011.simulation = "sim_011"
    req_011.net = "dut.power_in.hv"
    req_011.measurement = "peak_to_peak"
    assert req_011.limit within 0V to 100mV
    req_011.justification = "DS Fig 42: Input voltage ripple at 100mA DCM load."
    req_011.required_plot = "plot_011"

    # =================================================================
    # MV_012: Low Dropout — Vout regulation (DS Fig 43)
    # VIN=7V (near minimum), 5A load, EN forced high
    # =================================================================
    sim_012 = new SimulationTransient
    sim_012.duts = "dut"
    sim_012.spice = "V1 dut.power_in.hv 0 PULSE(0 7 0 10u 10u 10 10)"
    sim_012.remove_elements = "R3,R4,R5"
    sim_012.extra_spice = "V_EN dut.enable.line 0 DC 5|Iload dut.power_out.hv 0 DC 1|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_012.time_start = 15ms
    sim_012.time_stop = 15.5ms
    sim_012.time_step = 25ns

    plot_012 = new LineChart
    plot_012.title = "Low Dropout Operation (DS Fig 43)"
    plot_012.x = "time"
    plot_012.y = "dut.power_out.hv"
    plot_012.y_secondary = "i(l1)"
    plot_012.simulation = "sim_012"

    req_012 = new Requirement
    req_012.req_name = "MV_012: [Fig 43] Low Dropout — Vout regulation"
    req_012.simulation = "sim_012"
    req_012.net = "dut.power_out.hv"
    req_012.measurement = "average"
    assert req_012.limit within 4.5V to 5.25V
    req_012.justification = "DS Fig 43: Vout regulation at VIN=7V (near dropout, D~0.71)."
    req_012.required_plot = "plot_012"

    # =================================================================
    # MV_013: Load Regulation — Vout vs IOUT (DS Fig 50)
    # Sweep ILOAD at VIN=12V, measure average Vout
    # =================================================================
    sim_013 = new SimulationSweep
    sim_013.duts = "dut"
    sim_013.param_name = "ILOAD"
    sim_013.param_values = "0.5,1,2,3,4,5"
    sim_013.param_unit = "A"
    sim_013.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_013.remove_elements = "R5"
    sim_013.extra_spice_template = "I_LOAD dut.power_out.hv 0 DC {ILOAD}|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_013.time_start = 10ms
    sim_013.time_stop = 10.5ms
    sim_013.time_step = 500ns

    plot_013_bar = new BarChart
    plot_013_bar.title = "Load Regulation (DS Fig 50)"
    plot_013_bar.x = "ILOAD"
    plot_013_bar.y = "average(dut.power_out.hv)"
    plot_013_bar.simulation = "sim_013"

    plot_013_vout = new LineChart
    plot_013_vout.title = "Vout vs Load Current"
    plot_013_vout.x = "time"
    plot_013_vout.y = "dut.power_out.hv"
    plot_013_vout.color = "ILOAD"
    plot_013_vout.simulation = "sim_013"

    req_013 = new Requirement
    req_013.req_name = "MV_013: [Fig 50] Load Regulation — Vout vs IOUT"
    req_013.simulation = "sim_013"
    req_013.net = "dut.power_out.hv"
    req_013.measurement = "average"
    assert req_013.limit within 4.85V to 5.15V
    req_013.justification = "DS Fig 50: Load regulation within +/-0.6% across 0.5-5A."
    req_013.required_plot = "plot_013_bar"
    req_013.supplementary_plot = "plot_013_vout"

    # =================================================================
    # MV_014: Line Regulation — Vout vs VIN (DS Fig 51)
    # Sweep VIN at IOUT=5A, measure average Vout
    # =================================================================
    sim_014 = new SimulationSweep
    sim_014.duts = "dut"
    sim_014.param_name = "VIN"
    sim_014.param_values = "8,12,24,36,48,60"
    sim_014.param_unit = "V"
    sim_014.spice_template = "V1 dut.power_in.hv 0 PULSE(0 {VIN} 0 10u 10u 10 10)"
    sim_014.remove_elements = "R5"
    sim_014.extra_spice = "Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_014.time_start = 10ms
    sim_014.time_stop = 10.5ms
    sim_014.time_step = 500ns

    plot_014_bar = new BarChart
    plot_014_bar.title = "Line Regulation (DS Fig 51)"
    plot_014_bar.x = "VIN"
    plot_014_bar.y = "average(dut.power_out.hv)"
    plot_014_bar.simulation = "sim_014"

    plot_014_vout = new LineChart
    plot_014_vout.title = "Vout vs Input Voltage"
    plot_014_vout.x = "time"
    plot_014_vout.y = "dut.power_out.hv"
    plot_014_vout.color = "VIN"
    plot_014_vout.simulation = "sim_014"

    req_014 = new Requirement
    req_014.req_name = "MV_014: [Fig 51] Line Regulation — Vout vs VIN"
    req_014.simulation = "sim_014"
    req_014.net = "dut.power_out.hv"
    req_014.measurement = "average"
    assert req_014.limit within 4.85V to 5.15V
    req_014.justification = "DS Fig 51: Line regulation within +/-0.3% across 8-60V."
    req_014.required_plot = "plot_014_bar"
    req_014.supplementary_plot = "plot_014_vout"
