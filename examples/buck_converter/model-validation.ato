#pragma experiment("BRIDGE_CONNECT")

import SimulationTransient
import SimulationSweep
import SimulationAC
import Requirement
import StartupValidationChart
import EfficiencyValidationChart
import SweepOverlayChart
from "buck_converter.ato" import TPS54560_Reference

# =============================================================================
# TPS54560 Model Validation
# Datasheet: SLVSBN0C (March 2013, Rev March 2017)
# Section 8.2.3 — Application Curves (Figures 34–55)
# Section 6 — Typical Characteristics (Figure 21)
#
# DUT: 5V/5A output, 12V nominal input, 400kHz switching (DS Figure 33)
#
# 3.3V FB divider override (for Figs 46, 47):
#   Remove R1 (53.6k), add R_TOP_33 (31.6k) → Vout = 0.8*(31.6k+10k)/10k ≈ 3.28V
#   Remove R4, R5 (EN divider), force EN high — needed for VIN=6V (below UVLO)
# =============================================================================

module ModelValidation:
    "TPS54560 model validation — DS Section 8.2.3 Application Curves."

    dut = new TPS54560_Reference

    # =================================================================
    # SIMULATIONS
    # =================================================================

    # -----------------------------------------------------------------
    # 1. STARTUP (DS Figures 36, 37)
    # -----------------------------------------------------------------

    # Startup with VIN — frequency sweep (200kHz to 1.2MHz)
    # Sweeps switching frequency to show how rise time varies with fsw.
    startup_freq_sweep = new SimulationSweep
    startup_freq_sweep.param_name = "FS"
    startup_freq_sweep.param_values = "200000,300000,400000,500000,600000,700000,800000,900000,1000000,1100000,1200000"
    startup_freq_sweep.param_unit = "Hz"
    startup_freq_sweep.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    startup_freq_sweep.time_stop = 15e-3
    startup_freq_sweep.time_step = 1e-6
    startup_freq_sweep.remove_elements = "X1,V2,V3,V4,V5"
    startup_freq_sweep.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS={FS}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # Waveform overlay chart for Fig 36 frequency sweep
    fig36_chart = new SweepOverlayChart
    fig36_chart.title = "Start-up With VIN — Frequency Sweep (DS Fig 36)"
    fig36_chart.simulations = "startup_freq_sweep"
    fig36_chart.series_labels = "Freq Sweep"
    fig36_chart.net = "dut.power_out.hv"
    fig36_chart.measurement = "settling_time"
    fig36_chart.x_label = "Switching Frequency (Hz)"
    fig36_chart.y_label = "Settling Time (s)"
    fig36_chart.min_val = 0
    fig36_chart.max_val = 15e-3

    # Fig 37: Start-up with EN control (VIN=12V steady, EN pulse at 2ms)
    # DS scope: VIN (4V/div), EN (2V/div), VOUT (5V/div), time=2ms/div
    fig37_startup_en = new SimulationTransient
    fig37_startup_en.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig37_startup_en.time_stop = 20e-3
    fig37_startup_en.time_step = 1e-6
    fig37_startup_en.remove_elements = "X1,V2,V3,V4,V5,R4"
    fig37_startup_en.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_EN dut_package_en 0 PULSE(0 12 2e-3 10u 10u 10 10)|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 2. TRANSIENT RESPONSE (DS Figures 34, 35)
    # -----------------------------------------------------------------

    load_transient_sweep_load = new SimulationSweep
    load_transient_sweep_load.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    load_transient_sweep_load.extra_spice = "I_LOAD dut_power_out_hv 0 PULSE(0.25m {ILOAD} 7m 1u 1u 5m 20m)"
    load_transient_sweep_load.param_name = "ILOAD"
    load_transient_sweep_load.param_values = "1,2,3,4,5"
    load_transient_sweep_load.param_unit = "A"
    load_transient_sweep_load.time_start = 5ms
    load_transient_sweep_load.time_stop = 15ms
    load_transient_sweep_load.time_step = 100ns

    # Fig 35: Line transient — VIN step 8V to 40V
    # DS scope: VIN (10V/div), VOUT AC-coupled (10mV/div), time=4ms/div
    fig35_line_transient = new SimulationTransient
    fig35_line_transient.spice = "V1 dut_power_in_hv 0 PULSE(8 40 15e-3 1u 1u 5e-3 20e-3)"
    fig35_line_transient.time_start = 8e-3
    fig35_line_transient.time_stop = 30e-3
    fig35_line_transient.time_step = 1e-6
    fig35_line_transient.remove_elements = "X1,V2,V3,V4,V5"
    fig35_line_transient.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 3. OUTPUT RIPPLE (DS Figures 38, 39, 40)
    # At 400kHz, T=2.5us. Capture 40 cycles = 100us for robust p-p measurement.
    # -----------------------------------------------------------------

    # Fig 38: Output ripple, CCM (5A load)
    # DS scope: SW (10V/div), IL (1A/div), VOUT AC (10mV/div), time=4us/div
    fig38_ripple_ccm = new SimulationTransient
    fig38_ripple_ccm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig38_ripple_ccm.time_start = 10e-3
    fig38_ripple_ccm.time_stop = 10.1e-3
    fig38_ripple_ccm.time_step = 25e-9
    fig38_ripple_ccm.remove_elements = "X1,V2,V3,V4,V5"
    fig38_ripple_ccm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # Fig 39: Output ripple, DCM (IOUT=100mA, R=50 ohm)
    # DS scope: SW (10V/div), IL (500mA/div), VOUT AC (10mV/div), time=4us/div
    # DCM needs more settling time (20ms)
    fig39_ripple_dcm = new SimulationTransient
    fig39_ripple_dcm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig39_ripple_dcm.time_start = 20e-3
    fig39_ripple_dcm.time_stop = 20.1e-3
    fig39_ripple_dcm.time_step = 25e-9
    fig39_ripple_dcm.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig39_ripple_dcm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_DCM dut_power_out_hv 0 50|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # Fig 40: Output ripple, eco-mode / PSM (no load, 100k dummy)
    # DS scope: SW (10V/div), IL (1mA/div), VOUT AC (200mV/div), time=1ms/div
    # PSM has very slow pulse-skipping dynamics — need long window
    fig40_ripple_psm = new SimulationTransient
    fig40_ripple_psm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig40_ripple_psm.time_start = 10e-3
    fig40_ripple_psm.time_stop = 20e-3
    fig40_ripple_psm.time_step = 100e-9
    fig40_ripple_psm.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig40_ripple_psm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_PSM dut_power_out_hv 0 100k|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 4. INPUT RIPPLE (DS Figures 41, 42)
    # Same 40-cycle window as output ripple
    # -----------------------------------------------------------------

    # Fig 41: Input ripple, CCM (5A load)
    # DS scope: SW (10V/div), IL (200mA/div), VIN AC (10mV/div), time=4us/div
    fig41_input_ripple_ccm = new SimulationTransient
    fig41_input_ripple_ccm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig41_input_ripple_ccm.time_start = 10e-3
    fig41_input_ripple_ccm.time_stop = 10.1e-3
    fig41_input_ripple_ccm.time_step = 25e-9
    fig41_input_ripple_ccm.remove_elements = "X1,V2,V3,V4,V5"
    fig41_input_ripple_ccm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # Fig 42: Input ripple, DCM (IOUT=100mA, R=50 ohm)
    # DS scope: SW (10V/div), IL (500mA/div), VIN AC (20mV/div), time=4us/div
    fig42_input_ripple_dcm = new SimulationTransient
    fig42_input_ripple_dcm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig42_input_ripple_dcm.time_start = 20e-3
    fig42_input_ripple_dcm.time_stop = 20.1e-3
    fig42_input_ripple_dcm.time_step = 25e-9
    fig42_input_ripple_dcm.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig42_input_ripple_dcm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_DCM dut_power_out_hv 0 50|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 5. LOW DROPOUT (DS Figure 43)
    # VIN close to VOUT — near 100% duty cycle
    # DS scope: SW (20mV/div), VOUT (2V/div), IL (200mA/div), time=40us/div
    # VIN=7V with 5V output → low headroom (D ≈ 0.71)
    # DS minimum VIN = 7V for 5V output
    # -----------------------------------------------------------------

    fig43_low_dropout = new SimulationTransient
    fig43_low_dropout.spice = "V1 dut_power_in_hv 0 PULSE(0 7 0 10u 10u 10 10)"
    fig43_low_dropout.time_start = 10e-3
    fig43_low_dropout.time_stop = 10.5e-3
    fig43_low_dropout.time_step = 25e-9
    fig43_low_dropout.remove_elements = "X1,V2,V3,V4,V5,R4,R5"
    fig43_low_dropout.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_EN_FORCE dut_package_en 0 DC 5|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 6. EFFICIENCY vs LOAD CURRENT — 5V (DS Figure 44)
    # Sweep ILOAD at each VIN: 7, 12, 24, 36, 48, 60V
    # VOUT=5V, fsw=400kHz
    # Note: Behavioral model does not accurately model power loss.
    #       These sweeps produce waveform data but no pass/fail requirements.
    # -----------------------------------------------------------------

    fig44_eff_vin7 = new SimulationSweep
    fig44_eff_vin7.param_name = "ILOAD"
    fig44_eff_vin7.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin7.param_unit = "A"
    fig44_eff_vin7.spice = "V1 dut_power_in_hv 0 PULSE(0 7 0 10u 10u 10 10)"
    fig44_eff_vin7.time_start = 10e-3
    fig44_eff_vin7.time_stop = 10.5e-3
    fig44_eff_vin7.time_step = 500e-9
    fig44_eff_vin7.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin7.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig44_eff_vin12 = new SimulationSweep
    fig44_eff_vin12.param_name = "ILOAD"
    fig44_eff_vin12.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin12.param_unit = "A"
    fig44_eff_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig44_eff_vin12.time_start = 10e-3
    fig44_eff_vin12.time_stop = 10.5e-3
    fig44_eff_vin12.time_step = 500e-9
    fig44_eff_vin12.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin12.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig44_eff_vin24 = new SimulationSweep
    fig44_eff_vin24.param_name = "ILOAD"
    fig44_eff_vin24.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin24.param_unit = "A"
    fig44_eff_vin24.spice = "V1 dut_power_in_hv 0 PULSE(0 24 0 10u 10u 10 10)"
    fig44_eff_vin24.time_start = 10e-3
    fig44_eff_vin24.time_stop = 10.5e-3
    fig44_eff_vin24.time_step = 500e-9
    fig44_eff_vin24.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin24.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig44_eff_vin36 = new SimulationSweep
    fig44_eff_vin36.param_name = "ILOAD"
    fig44_eff_vin36.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin36.param_unit = "A"
    fig44_eff_vin36.spice = "V1 dut_power_in_hv 0 PULSE(0 36 0 10u 10u 10 10)"
    fig44_eff_vin36.time_start = 10e-3
    fig44_eff_vin36.time_stop = 10.5e-3
    fig44_eff_vin36.time_step = 500e-9
    fig44_eff_vin36.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin36.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig44_eff_vin48 = new SimulationSweep
    fig44_eff_vin48.param_name = "ILOAD"
    fig44_eff_vin48.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin48.param_unit = "A"
    fig44_eff_vin48.spice = "V1 dut_power_in_hv 0 PULSE(0 48 0 10u 10u 10 10)"
    fig44_eff_vin48.time_start = 10e-3
    fig44_eff_vin48.time_stop = 10.5e-3
    fig44_eff_vin48.time_step = 500e-9
    fig44_eff_vin48.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin48.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig44_eff_vin60 = new SimulationSweep
    fig44_eff_vin60.param_name = "ILOAD"
    fig44_eff_vin60.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin60.param_unit = "A"
    fig44_eff_vin60.spice = "V1 dut_power_in_hv 0 PULSE(0 60 0 10u 10u 10 10)"
    fig44_eff_vin60.time_start = 10e-3
    fig44_eff_vin60.time_stop = 10.5e-3
    fig44_eff_vin60.time_step = 500e-9
    fig44_eff_vin60.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig44_eff_vin60.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 7. LIGHT LOAD EFFICIENCY — 5V (DS Figure 45)
    # Log-scale current sweep: 1mA to 1A
    # -----------------------------------------------------------------

    fig45_light_eff_vin12 = new SimulationSweep
    fig45_light_eff_vin12.param_name = "ILOAD"
    fig45_light_eff_vin12.param_values = "0.001,0.005,0.01,0.05,0.1,0.5,1"
    fig45_light_eff_vin12.param_unit = "A"
    fig45_light_eff_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig45_light_eff_vin12.time_start = 20e-3
    fig45_light_eff_vin12.time_stop = 21e-3
    fig45_light_eff_vin12.time_step = 500e-9
    fig45_light_eff_vin12.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig45_light_eff_vin12.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig45_light_eff_vin48 = new SimulationSweep
    fig45_light_eff_vin48.param_name = "ILOAD"
    fig45_light_eff_vin48.param_values = "0.001,0.005,0.01,0.05,0.1,0.5,1"
    fig45_light_eff_vin48.param_unit = "A"
    fig45_light_eff_vin48.spice = "V1 dut_power_in_hv 0 PULSE(0 48 0 10u 10u 10 10)"
    fig45_light_eff_vin48.time_start = 20e-3
    fig45_light_eff_vin48.time_stop = 21e-3
    fig45_light_eff_vin48.time_step = 500e-9
    fig45_light_eff_vin48.remove_elements = "X1,V2,V3,V4,V5,R6"
    fig45_light_eff_vin48.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    # -----------------------------------------------------------------
    # 8. EFFICIENCY vs LOAD CURRENT — 3.3V (DS Figure 46)
    # Same as Fig 44 but with 3.3V FB divider: R7→31.6k (R1=10.2k stays)
    # Vout = 0.8 * (31.6k + 10.2k) / 10.2k ≈ 3.28V
    # EN divider removed and forced high for VIN=6V operation
    # VIN sweep: 6, 12, 24, 36, 48, 60V
    # -----------------------------------------------------------------

    fig46_eff_3v3_vin6 = new SimulationSweep
    fig46_eff_3v3_vin6.param_name = "ILOAD"
    fig46_eff_3v3_vin6.param_values = "0.5,1,2,3,4,5"
    fig46_eff_3v3_vin6.param_unit = "A"
    fig46_eff_3v3_vin6.spice = "V1 dut_power_in_hv 0 PULSE(0 6 0 10u 10u 10 10)"
    fig46_eff_3v3_vin6.time_start = 10e-3
    fig46_eff_3v3_vin6.time_stop = 10.5e-3
    fig46_eff_3v3_vin6.time_step = 500e-9
    fig46_eff_3v3_vin6.remove_elements = "X1,V2,V3,V4,V5,R6,R1,R4,R5"
    fig46_eff_3v3_vin6.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_TOP_33 dut_power_out_hv dut_package_5 31.6k|V_EN_FORCE dut_package_en 0 DC 5|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}|C_OUT1 dut_power_out_hv 0 47u|C_OUT2 dut_power_out_hv 0 47u|C_OUT3 dut_power_out_hv 0 47u"

    fig46_eff_3v3_vin12 = new SimulationSweep
    fig46_eff_3v3_vin12.param_name = "ILOAD"
    fig46_eff_3v3_vin12.param_values = "0.5,1,2,3,4,5"
    fig46_eff_3v3_vin12.param_unit = "A"
    fig46_eff_3v3_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig46_eff_3v3_vin12.time_start = 10e-3
    fig46_eff_3v3_vin12.time_stop = 10.5e-3
    fig46_eff_3v3_vin12.time_step = 500e-9
