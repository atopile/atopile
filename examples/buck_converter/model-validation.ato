#pragma experiment("BRIDGE_CONNECT")

import SimulationTransient
import SimulationSweep
import LineChart
import BarChart
import Requirement

from "buck_converter.ato" import TPS54560_Reference

# =============================================================================
# TPS54560 Model Validation
# Datasheet: SLVSBN0C (March 2013, Rev March 2017)
# Section 8.2.3 — Application Curves (Figures 34–55)
#
# DUT: 5V/5A output, 12V nominal input, 400kHz switching (DS Figure 33)
#
# Netlist element map (from ato build):
#   R1=r_bottom(10.2k) R2=r_comp(16.9k) R3=r_en(442k) R4=r_en_bot(90.9k)
#   R5=r_load(1k) R6=r_rt(243k) R7=r_top(53.6k)
#   C1=c_boot(100n) C2=c_comp(4.7n) C3=c_comp1(47p) C4=c_in(10u)
#   C5-C8=c_out(4x47u) — NOTE: MultiCapacitor values don't resolve in SPICE,
#   so output caps are manually added via extra_spice on each simulation.
#   L1=inductor(6.8u)  X1=TPS54560_TRANS(FS=param_bindings)
#
# Known model limitations:
#   - Ideal voltage sources: input ripple always 0 (Figs 41-42 not testable)
#   - Behavioral switches: efficiency not modelable (Figs 44-48 not testable)
#   - No EN pullup current: UVLO start voltage differs from DS by ~0.5V
#   - No thermal model: Figs 52-55 not testable
# =============================================================================

module ModelValidation:
    "TPS54560 model validation — DS Section 8.2.3 Application Curves."

    dut = new TPS54560_Reference
    assert dut.power_out.voltage within 5V +/- 5%
    assert dut.power_in.voltage within 12V +/- 5%
    assert dut.switching_frequency within 400kHz +/- 5%
    dut.power_out.max_current = 5A

    # =====================================================================
    # SIMULATION: EN-Controlled Startup (DS Figure 37)
    # VIN=12V steady, EN pulse at 1ms. Validates soft-start and regulation.
    # Shared by: MV_001 (final_value), MV_002 (settling_time)
    # =====================================================================
    sim_startup_en = new SimulationTransient
    sim_startup_en.duts = "dut"
    sim_startup_en.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_startup_en.remove_elements = "R3,R4"
    sim_startup_en.extra_spice = "V_EN dut.enable.line 0 PULSE(0 12 1e-3 10u 10u 10 10)|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_startup_en.time_stop = 10ms
    sim_startup_en.time_step = 2us

    # =====================================================================
    # SIMULATION: VIN-Ramp Startup (DS Figure 36)
    # VIN ramps 0->12V in 1ms, EN follows via R3/R4 divider.
    # Device enables when EN > 1.2V (VIN ~ 7V due to divider ratio 0.17).
    # Shared by: MV_003 (final_value)
    # =====================================================================
    sim_startup_vin = new SimulationTransient
    sim_startup_vin.duts = "dut"
    sim_startup_vin.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 1m 0 10 10)"
    sim_startup_vin.extra_spice = "Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_startup_vin.time_stop = 10ms
    sim_startup_vin.time_step = 2us

    # =====================================================================
    # SIMULATION: Load Transient (DS Figure 34, Table 1)
    # Load step 1.25A -> 3.75A (DS spec: dVout <= 4% = 200mV).
    # Shared by: MV_004 (peak_to_peak)
    # =====================================================================
    sim_load_transient = new SimulationTransient
    sim_load_transient.duts = "dut"
    sim_load_transient.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_load_transient.remove_elements = "R3,R4,R5"
    sim_load_transient.extra_spice = "V_EN dut.enable.line 0 DC 12|I_LOAD dut.power_out.hv 0 PULSE(1.25 3.75 7m 1u 1u 3m 20m)|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_load_transient.time_start = 6ms
    sim_load_transient.time_stop = 12ms
    sim_load_transient.time_step = 500ns

    # =====================================================================
    # SIMULATION: Line Transient (DS Figure 35)
    # VIN step 8V -> 40V at 15ms, validates loop regulation.
    # Shared by: MV_005 (peak_to_peak)
    # =====================================================================
    sim_line_transient = new SimulationTransient
    sim_line_transient.duts = "dut"
    sim_line_transient.spice = "V1 dut.power_in.hv 0 PULSE(8 40 15e-3 1u 1u 5e-3 20e-3)"
    sim_line_transient.remove_elements = "R3,R4"
    sim_line_transient.extra_spice = "V_EN dut.enable.line 0 DC 12|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_line_transient.time_start = 12ms
    sim_line_transient.time_stop = 20ms
    sim_line_transient.time_step = 5us

    # =====================================================================
    # SIMULATION: CCM Steady-State Ripple (DS Figure 38)
    # 5A load at VIN=12V. Captures ripple, frequency, IL, duty cycle.
    # Shared by: MV_006 (vout ripple), MV_007 (freq), MV_008 (IL avg),
    #            MV_009 (IL ripple), MV_010 (duty cycle)
    # =====================================================================
    sim_ccm_ripple = new SimulationTransient
    sim_ccm_ripple.duts = "dut"
    sim_ccm_ripple.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_ccm_ripple.remove_elements = "R3,R4,R5"
    sim_ccm_ripple.extra_spice = "V_EN dut.enable.line 0 DC 12|Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_ccm_ripple.time_start = 10ms
    sim_ccm_ripple.time_stop = 10.05ms
    sim_ccm_ripple.time_step = 10ns

    # =====================================================================
    # SIMULATION: DCM Steady-State Ripple (DS Figure 39)
    # 100mA load (50 ohm) at VIN=12V. DCM boundary at 408mA (DS 8.2.12).
    # Shared by: MV_011 (vout ripple), MV_012 (IL min ~ 0)
    # =====================================================================
    sim_dcm_ripple = new SimulationTransient
    sim_dcm_ripple.duts = "dut"
    sim_dcm_ripple.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_dcm_ripple.remove_elements = "R3,R4,R5"
    sim_dcm_ripple.extra_spice = "V_EN dut.enable.line 0 DC 12|R_LOAD_DCM dut.power_out.hv 0 50|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_dcm_ripple.time_start = 20ms
    sim_dcm_ripple.time_stop = 20.5ms
    sim_dcm_ripple.time_step = 50ns

    # =====================================================================
    # SIMULATION: PSM/Eco-mode Ripple (DS Figure 40)
    # Near-zero load (100k ohm). Eco-mode at <25.3mA (DS 8.2.12).
    # Shared by: MV_013
    # =====================================================================
    sim_psm_ripple = new SimulationTransient
    sim_psm_ripple.duts = "dut"
    sim_psm_ripple.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_psm_ripple.remove_elements = "R3,R4,R5"
    sim_psm_ripple.extra_spice = "V_EN dut.enable.line 0 DC 12|R_LOAD_PSM dut.power_out.hv 0 100k|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_psm_ripple.time_start = 15ms
    sim_psm_ripple.time_stop = 20ms
    sim_psm_ripple.time_step = 5us

    # =====================================================================
    # SIMULATION: Low Dropout (DS Figure 43)
    # VIN=7V (near minimum), 1A load, EN forced.
    # D ~ 5/7 = 0.71, validates high duty cycle operation.
    # Shared by: MV_014
    # =====================================================================
    sim_low_dropout = new SimulationTransient
    sim_low_dropout.duts = "dut"
    sim_low_dropout.spice = "V1 dut.power_in.hv 0 PULSE(0 7 0 10u 10u 10 10)"
    sim_low_dropout.remove_elements = "R3,R4,R5"
    sim_low_dropout.extra_spice = "V_EN dut.enable.line 0 DC 5|Iload dut.power_out.hv 0 DC 1|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_low_dropout.time_start = 15ms
    sim_low_dropout.time_stop = 15.1ms
    sim_low_dropout.time_step = 25ns

    # =====================================================================
    # SIMULATION: Load Regulation Sweep (DS Figure 50)
    # VIN=12V, sweep ILOAD 0.5-5A, measure average Vout.
    # Shared by: MV_015
    # =====================================================================
    sim_load_regulation = new SimulationSweep
    sim_load_regulation.duts = "dut"
    sim_load_regulation.param_name = "ILOAD"
    sim_load_regulation.param_values = "0.5,1,2,3,4,5"
    sim_load_regulation.param_unit = "A"
    sim_load_regulation.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_load_regulation.remove_elements = "R3,R4,R5"
    sim_load_regulation.extra_spice_template = "V_EN dut.enable.line 0 DC 12|I_LOAD dut.power_out.hv 0 DC {ILOAD}|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_load_regulation.time_start = 10ms
    sim_load_regulation.time_stop = 10.5ms
    sim_load_regulation.time_step = 500ns

    # =====================================================================
    # SIMULATION: Line Regulation Sweep (DS Figure 51)
    # IOUT=5A, sweep VIN 8-60V, measure average Vout.
    # Shared by: MV_016
    # =====================================================================
    sim_line_regulation = new SimulationSweep
    sim_line_regulation.duts = "dut"
    sim_line_regulation.param_name = "VIN"
    sim_line_regulation.param_values = "8,12,24,36,48,60"
    sim_line_regulation.param_unit = "V"
    sim_line_regulation.spice_template = "V1 dut.power_in.hv 0 PULSE(0 {VIN} 0 10u 10u 10 10)"
    sim_line_regulation.remove_elements = "R3,R4,R5"
    sim_line_regulation.extra_spice = "V_EN dut.enable.line 0 DC 12|Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_line_regulation.time_start = 10ms
    sim_line_regulation.time_stop = 10.5ms
    sim_line_regulation.time_step = 500ns

    # =====================================================================
    # SIMULATION: High VIN Steady-State (VIN=48V)
    # D ~ 5/48 = 10.4%, on-time ~ 260ns. Tests narrow pulse operation.
    # Shared by: MV_017
    # =====================================================================
    sim_high_vin = new SimulationTransient
    sim_high_vin.duts = "dut"
    sim_high_vin.spice = "V1 dut.power_in.hv 0 PULSE(0 48 0 10u 10u 10 10)"
    sim_high_vin.remove_elements = "R3,R4,R5"
    sim_high_vin.extra_spice = "V_EN dut.enable.line 0 DC 12|Iload dut.power_out.hv 0 DC 5|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_high_vin.time_start = 10ms
    sim_high_vin.time_stop = 10.05ms
    sim_high_vin.time_step = 10ns

    # =====================================================================
    # SIMULATION: Overcurrent Protection (DS Section 7.3.8)
    # 8A load at VIN=12V. OCP range: 6.3-8.8A (DS Table 7.6).
    # Model should limit current and reduce Vout.
    # Shared by: MV_018
    # =====================================================================
    sim_ocp = new SimulationTransient
    sim_ocp.duts = "dut"
    sim_ocp.spice = "V1 dut.power_in.hv 0 PULSE(0 12 0 10u 10u 10 10)"
    sim_ocp.remove_elements = "R3,R4,R5"
    sim_ocp.extra_spice = "V_EN dut.enable.line 0 DC 12|Iload dut.power_out.hv 0 DC 8|Cout1 dut.power_out.hv 0 47u|Cout2 dut.power_out.hv 0 47u|Cout3 dut.power_out.hv 0 47u|Cout4 dut.power_out.hv 0 47u"
    sim_ocp.time_start = 10ms
    sim_ocp.time_stop = 10.05ms
    sim_ocp.time_step = 10ns

    # =====================================================================
    # PLOTS
    # =====================================================================

    # --- Startup EN ---
    plot_001 = new LineChart
    plot_001.title = "EN-Controlled Startup (DS Fig 37)"
    plot_001.x = "time"
    plot_001.y = "dut.power_out.hv"
    plot_001.y_secondary = "i(l1)"
    plot_001.simulation = "sim_startup_en"
    assert plot_001.y_range within 3V +/- 3V

    # --- Startup VIN ---
    plot_003 = new LineChart
    plot_003.title = "VIN-Ramp Startup (DS Fig 36)"
    plot_003.x = "time"
    plot_003.y = "dut.power_out.hv"
    plot_003.y_secondary = "dut.power_in.hv"
    plot_003.simulation = "sim_startup_vin"
    assert plot_003.y_range within 3V +/- 3V

    # --- Load Transient ---
    plot_004 = new LineChart
    plot_004.title = "Load Transient 1.25A to 3.75A (DS Fig 34)"
    plot_004.x = "time"
    plot_004.y = "ac_coupled(dut.power_out.hv)"
    plot_004.y_secondary = "i(l1)"
    plot_004.simulation = "sim_load_transient"
    assert plot_004.y_range within 0V +/- 300mV

    # --- Line Transient ---
    plot_005 = new LineChart
    plot_005.title = "Line Transient 8V to 40V (DS Fig 35)"
    plot_005.x = "time"
    plot_005.y = "ac_coupled(dut.power_out.hv)"
    plot_005.y_secondary = "dut.power_in.hv"
    plot_005.simulation = "sim_line_transient"
    assert plot_005.y_range within 0V +/- 250mV

    # --- Load Transient (raw Vout for context) ---
    plot_004_raw = new LineChart
    plot_004_raw.title = "Load Transient — Absolute Vout"
    plot_004_raw.x = "time"
    plot_004_raw.y = "dut.power_out.hv"
    plot_004_raw.y_secondary = "i(l1)"
    plot_004_raw.simulation = "sim_load_transient"
    plot_004_raw.plot_limits = "false"
    assert plot_004_raw.y_range within 5V +/- 500mV

    # --- CCM Ripple (shared sim — 3 plots for 5 reqs) ---
    plot_ccm_vout = new LineChart
    plot_ccm_vout.title = "CCM Output Ripple at 5A (DS Fig 38)"
    plot_ccm_vout.x = "time"
    plot_ccm_vout.y = "ac_coupled(dut.power_out.hv)"
    plot_ccm_vout.y_secondary = "i(l1)"
    plot_ccm_vout.simulation = "sim_ccm_ripple"
    assert plot_ccm_vout.y_range within 0V +/- 15mV

    plot_ccm_sw = new LineChart
    plot_ccm_sw.title = "CCM SW Node and Inductor Current (DS Fig 38)"
    plot_ccm_sw.x = "time"
    plot_ccm_sw.y = "dut.package.SW"
    plot_ccm_sw.y_secondary = "i(l1)"
    plot_ccm_sw.simulation = "sim_ccm_ripple"

    plot_ccm_il = new LineChart
    plot_ccm_il.title = "CCM Inductor Current at 5A (DS Fig 38)"
    plot_ccm_il.x = "time"
    plot_ccm_il.y = "i(l1)"
    plot_ccm_il.simulation = "sim_ccm_ripple"

    # --- DCM Ripple (shared sim — 2 plots for 2 reqs) ---
    plot_dcm_vout = new LineChart
    plot_dcm_vout.title = "DCM Output Ripple at 100mA (DS Fig 39)"
    plot_dcm_vout.x = "time"
    plot_dcm_vout.y = "ac_coupled(dut.power_out.hv)"
    plot_dcm_vout.y_secondary = "i(l1)"
    plot_dcm_vout.simulation = "sim_dcm_ripple"
    assert plot_dcm_vout.y_range within 0V +/- 100mV

    plot_dcm_il = new LineChart
    plot_dcm_il.title = "DCM Inductor Current at 100mA (DS Fig 39)"
    plot_dcm_il.x = "time"
    plot_dcm_il.y = "i(l1)"
    plot_dcm_il.simulation = "sim_dcm_ripple"

    # --- PSM Ripple ---
    plot_psm_vout = new LineChart
    plot_psm_vout.title = "PSM Eco-mode Ripple, No Load (DS Fig 40)"
    plot_psm_vout.x = "time"
    plot_psm_vout.y = "ac_coupled(dut.power_out.hv)"
    plot_psm_vout.y_secondary = "i(l1)"
    plot_psm_vout.simulation = "sim_psm_ripple"
    assert plot_psm_vout.y_range within 0V +/- 10mV

    # --- Low Dropout ---
    plot_014 = new LineChart
    plot_014.title = "Low Dropout VIN=7V, 1A (DS Fig 43)"
    plot_014.x = "time"
    plot_014.y = "dut.power_out.hv"
    plot_014.y_secondary = "i(l1)"
    plot_014.simulation = "sim_low_dropout"
    assert plot_014.y_range within 5V +/- 500mV

    plot_014_sw = new LineChart
    plot_014_sw.title = "Low Dropout SW Node — High Duty Cycle"
    plot_014_sw.x = "time"
    plot_014_sw.y = "dut.package.SW"
    plot_014_sw.y_secondary = "i(l1)"
    plot_014_sw.simulation = "sim_low_dropout"
    plot_014_sw.plot_limits = "false"

    # --- Load Regulation ---
    plot_015_bar = new BarChart
    plot_015_bar.title = "Load Regulation (DS Fig 50)"
    plot_015_bar.x = "ILOAD"
    plot_015_bar.y = "average(dut.power_out.hv)"
    plot_015_bar.simulation = "sim_load_regulation"

    plot_015_vout = new LineChart
    plot_015_vout.title = "Vout vs Load Current (DS Fig 50)"
    plot_015_vout.x = "time"
    plot_015_vout.y = "dut.power_out.hv"
    plot_015_vout.color = "ILOAD"
    plot_015_vout.simulation = "sim_load_regulation"
    assert plot_015_vout.y_range within 5V +/- 200mV

    # --- Line Regulation ---
    plot_016_bar = new BarChart
    plot_016_bar.title = "Line Regulation (DS Fig 51)"
    plot_016_bar.x = "VIN"
    plot_016_bar.y = "average(dut.power_out.hv)"
    plot_016_bar.simulation = "sim_line_regulation"

    plot_016_vout = new LineChart
    plot_016_vout.title = "Vout vs Input Voltage (DS Fig 51)"
    plot_016_vout.x = "time"
    plot_016_vout.y = "dut.power_out.hv"
    plot_016_vout.color = "VIN"
    plot_016_vout.simulation = "sim_line_regulation"
    assert plot_016_vout.y_range within 5V +/- 200mV

    # --- High VIN ---
    plot_017 = new LineChart
    plot_017.title = "High VIN=48V SW Node and IL"
    plot_017.x = "time"
    plot_017.y = "dut.package.SW"
    plot_017.y_secondary = "i(l1)"
    plot_017.simulation = "sim_high_vin"

    plot_017_vout = new LineChart
    plot_017_vout.title = "High VIN=48V Output Ripple"
    plot_017_vout.x = "time"
    plot_017_vout.y = "ac_coupled(dut.power_out.hv)"
    plot_017_vout.y_secondary = "i(l1)"
    plot_017_vout.simulation = "sim_high_vin"
    plot_017_vout.plot_limits = "false"
    assert plot_017_vout.y_range within 0V +/- 20mV

    # --- OCP ---
    plot_ocp = new LineChart
    plot_ocp.title = "OCP: 8A Overload — IL and Vout (DS Sec 7.3.8)"
    plot_ocp.x = "time"
    plot_ocp.y = "i(l1)"
    plot_ocp.y_secondary = "dut.power_out.hv"
    plot_ocp.simulation = "sim_ocp"

    # =====================================================================
    # REQUIREMENTS (18 total, 12 simulations, 20 plots)
    # =====================================================================

    # --- MV_001: EN Startup — Vout reaches regulation ---
    req_001 = new Requirement
    req_001.req_name = "MV_001: [Fig 37] EN Startup — Vout regulation"
    req_001.simulation = "sim_startup_en"
    req_001.net = "dut.power_out.hv"
    req_001.measurement = "final_value"
    assert req_001.limit within 4.75V to 5.30V
    req_001.justification = "DS Fig 37: EN-controlled startup must reach ~5V regulation. Slightly above 5.25V due to FB divider tolerance."
    req_001.required_plot = "plot_001"

    # --- MV_002: EN Startup — Soft-start settling time ---
    # DS Eq 6: tss = 1024/fsw = 1024/400kHz = 2.56ms.
    # EN goes high at 1ms, total settling ~ 1ms + 2.56ms + LC delay ~ 4ms.
    req_002 = new Requirement
    req_002.req_name = "MV_002: [Fig 37] EN Startup — Soft-start timing"
    req_002.simulation = "sim_startup_en"
    req_002.net = "dut.power_out.hv"
    req_002.measurement = "settling_time"
    assert req_002.limit within 2ms to 10ms
    req_002.justification = "DS Eq 6: tss=1024/fsw=2.56ms. With 1ms EN delay + LC settling, total ~5-8ms."
    req_002.required_plot = "plot_001"

    # --- MV_003: VIN Startup — Vout reaches regulation ---
    req_003 = new Requirement
    req_003.req_name = "MV_003: [Fig 36] VIN Startup — Vout regulation"
    req_003.simulation = "sim_startup_vin"
    req_003.net = "dut.power_out.hv"
    req_003.measurement = "final_value"
    assert req_003.limit within 4.75V to 5.30V
    req_003.justification = "DS Fig 36: VIN-ramp startup must reach ~5V regulation."
    req_003.required_plot = "plot_003"

    # --- MV_004: Load Transient — Vout perturbation ---
    req_004 = new Requirement
    req_004.req_name = "MV_004: [Fig 34] Load Transient — Vout perturbation"
    req_004.simulation = "sim_load_transient"
    req_004.net = "dut.power_out.hv"
    req_004.measurement = "peak_to_peak"
    assert req_004.limit within 0V to 400mV
    req_004.justification = "DS Table 1/Fig 34: 2.5A load step, dVout < 4%. 400mV limit for model margin."
    req_004.required_plot = "plot_004"
    req_004.supplementary_plot = "plot_004_raw"

    # --- MV_005: Line Transient — Vout perturbation ---
    req_005 = new Requirement
    req_005.req_name = "MV_005: [Fig 35] Line Transient — Vout perturbation"
    req_005.simulation = "sim_line_transient"
    req_005.net = "dut.power_out.hv"
    req_005.measurement = "peak_to_peak"
    assert req_005.limit within 0V to 300mV
    req_005.justification = "DS Fig 35: Line transient 8V-40V, Vout perturbation <300mV."
    req_005.required_plot = "plot_005"

    # --- MV_006: CCM Output Ripple ---
    req_006 = new Requirement
    req_006.req_name = "MV_006: [Fig 38] CCM Output Ripple"
    req_006.simulation = "sim_ccm_ripple"
    req_006.net = "dut.power_out.hv"
    req_006.measurement = "peak_to_peak"
    assert req_006.limit within 0V to 10mV
    req_006.justification = "DS Eq 34: Vripple = IL_pp/(8*fsw*Cout) = 1.07/(8*400k*188u) ~ 1.8mV. Tight 10mV limit validates effective output capacitance."
    req_006.required_plot = "plot_ccm_vout"
    req_006.supplementary_plot = "plot_ccm_sw"

    # --- MV_007: CCM Switching Frequency ---
    req_007 = new Requirement
    req_007.req_name = "MV_007: [Fig 38] CCM Switching Frequency"
    req_007.simulation = "sim_ccm_ripple"
    req_007.net = "dut.package.SW"
    req_007.measurement = "frequency"
    assert req_007.limit within 360kHz to 440kHz
    req_007.justification = "DS: fsw=400kHz +/-10%. Validates FS parameter and oscillator model."
    req_007.required_plot = "plot_ccm_sw"

    # --- MV_008: CCM Inductor Current Average ---
    req_008 = new Requirement
    req_008.req_name = "MV_008: [Fig 38] CCM Inductor Current Average"
    req_008.simulation = "sim_ccm_ripple"
    req_008.net = "i(l1)"
    req_008.measurement = "average"
    assert req_008.limit within 4.5A to 5.5A
    req_008.justification = "IL_avg = Iout = 5A in steady-state CCM. Tight +/-10% validates power stage balance."
    req_008.required_plot = "plot_ccm_il"

    # --- MV_009: CCM Inductor Ripple ---
    # DS Eq 29: I_ripple = Vout*(VIN-Vout)/(VIN*L*fsw) = 5*7/(12*6.8u*400k) ~ 1.07A
    req_009 = new Requirement
    req_009.req_name = "MV_009: [Fig 38] CCM Inductor Current Ripple"
    req_009.simulation = "sim_ccm_ripple"
    req_009.net = "i(l1)"
    req_009.measurement = "peak_to_peak"
    assert req_009.limit within 800mA to 1.5A
    req_009.justification = "DS Eq 29: IL_pp = Vout*(VIN-Vout)/(VIN*L*fsw) = 5*7/(12*6.8u*400k) = 1.07A. Tight limit validates inductor value and duty cycle."
    req_009.required_plot = "plot_ccm_il"
    req_009.supplementary_plot = "plot_ccm_vout"

    # --- MV_010: CCM Duty Cycle ---
    req_010 = new Requirement
    req_010.req_name = "MV_010: [Fig 38] CCM Duty Cycle"
    req_010.simulation = "sim_ccm_ripple"
    req_010.net = "dut.package.SW"
    req_010.measurement = "duty_cycle"
    assert req_010.limit within 0.35 to 0.55
    req_010.justification = "D ~ Vout/VIN = 5/12 = 0.417. With RDSon+diode losses, D ~ 0.42-0.49."
    req_010.required_plot = "plot_ccm_sw"
    req_010.supplementary_plot = "plot_ccm_il"

    # --- MV_011: DCM Output Ripple ---
    req_011 = new Requirement
    req_011.req_name = "MV_011: [Fig 39] DCM Output Ripple"
    req_011.simulation = "sim_dcm_ripple"
    req_011.net = "dut.power_out.hv"
    req_011.measurement = "peak_to_peak"
    assert req_011.limit within 0V to 120mV
    req_011.justification = "DS Fig 39: DCM ripple at 100mA load (50 ohm). Higher than CCM due to larger current pulses."
    req_011.required_plot = "plot_dcm_vout"

    # --- MV_012: DCM Inductor Current Minimum ---
    req_012 = new Requirement
    req_012.req_name = "MV_012: [Fig 39] DCM Inductor Current Min"
    req_012.simulation = "sim_dcm_ripple"
    req_012.net = "i(l1)"
    req_012.measurement = "min"
    assert req_012.limit within -100mA to 100mA
    req_012.justification = "DCM: inductor current must reach ~0A each cycle. Catch diode clamps negative current. Tight limit proves DCM mode."
    req_012.required_plot = "plot_dcm_il"
    req_012.supplementary_plot = "plot_dcm_vout"

    # --- MV_013: PSM/Eco-mode Output Ripple ---
    req_013 = new Requirement
    req_013.req_name = "MV_013: [Fig 40] PSM Eco-mode Output Ripple"
    req_013.simulation = "sim_psm_ripple"
    req_013.net = "dut.power_out.hv"
    req_013.measurement = "peak_to_peak"
    assert req_013.limit within 0V to 20mV
    req_013.justification = "DS Fig 40: Eco-mode (no load) ripple. With 188uF Cout, ripple stays very small despite pulse-skipping."
    req_013.required_plot = "plot_psm_vout"

    # --- MV_014: Low Dropout — Vout regulation ---
    req_014 = new Requirement
    req_014.req_name = "MV_014: [Fig 43] Low Dropout — Vout regulation"
    req_014.simulation = "sim_low_dropout"
    req_014.net = "dut.power_out.hv"
    req_014.measurement = "average"
    assert req_014.limit within 4.5V to 5.25V
    req_014.justification = "DS Fig 43: Vout regulation at VIN=7V, D~0.71. Near dropout."
    req_014.required_plot = "plot_014"
    req_014.supplementary_plot = "plot_014_sw"

    # --- MV_015: Load Regulation — Vout vs IOUT ---
    req_015 = new Requirement
    req_015.req_name = "MV_015: [Fig 50] Load Regulation — Vout vs IOUT"
    req_015.simulation = "sim_load_regulation"
    req_015.net = "dut.power_out.hv"
    req_015.measurement = "average"
    assert req_015.limit within 4.85V to 5.15V
    req_015.justification = "DS Fig 50: Load regulation within +/-0.6% across 0.5-5A."
    req_015.required_plot = "plot_015_bar"
    req_015.supplementary_plot = "plot_015_vout"

    # --- MV_016: Line Regulation — Vout vs VIN ---
    req_016 = new Requirement
    req_016.req_name = "MV_016: [Fig 51] Line Regulation — Vout vs VIN"
    req_016.simulation = "sim_line_regulation"
    req_016.net = "dut.power_out.hv"
    req_016.measurement = "average"
    assert req_016.limit within 4.85V to 5.15V
    req_016.justification = "DS Fig 51: Line regulation within +/-0.3% across 8-60V."
    req_016.required_plot = "plot_016_bar"
    req_016.supplementary_plot = "plot_016_vout"

    # --- MV_017: High VIN Duty Cycle ---
    req_017 = new Requirement
    req_017.req_name = "MV_017: High VIN=48V Duty Cycle"
    req_017.simulation = "sim_high_vin"
    req_017.net = "dut.package.SW"
    req_017.measurement = "duty_cycle"
    assert req_017.limit within 0.05 to 0.20
    req_017.justification = "D ~ Vout/VIN = 5/48 = 0.104. Validates narrow-pulse operation at high VIN."
    req_017.required_plot = "plot_017"
    req_017.supplementary_plot = "plot_017_vout"

    # --- MV_018: Overcurrent Protection — Peak IL limited ---
    # DS: OCP at 6.3-8.8A. Model COMP clamp at 1.05V limits sense_sum.
    # With 8A load, inductor current should be clamped by cycle-by-cycle limiting.
    req_018 = new Requirement
    req_018.req_name = "MV_018: [Sec 7.3.8] OCP — Peak Inductor Current"
    req_018.simulation = "sim_ocp"
    req_018.net = "i(l1)"
    req_018.measurement = "max"
    assert req_018.limit within 5A to 10A
    req_018.justification = "DS OCP: 6.3-8.8A range. Model limits via COMP clamp at 1.05V. Peak IL should be limited but >5A since OCP is above nominal 5A."
    req_018.required_plot = "plot_ocp"
