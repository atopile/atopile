#pragma experiment("BRIDGE_CONNECT")

import SimulationTransient
import SimulationSweep
import SimulationAC
import Requirement
from "buck_converter.ato" import TI_TPS54560

# =============================================================================
# TPS54560 Model Validation
# Datasheet: SLVSBN0C (March 2013, Rev March 2017)
# Section 8.2.3 — Application Curves (Figures 34–55)
# Section 6 — Typical Characteristics (Figure 21)
#
# DUT: 5V/5A output, 12V nominal input, 400kHz switching (DS Figure 33)
#
# Coverage:
#   Fig 21  — Soft-Start Time vs Switching Frequency     [4 sims, 7 reqs]
#   Fig 34  — Load Transient                             [1 sim,  1 req]
#   Fig 35  — Line Transient (8V to 40V)                 [1 sim,  1 req]
#   Fig 36  — Start-up With VIN                          [1 sim,  3 reqs]
#   Fig 37  — Start-up With EN                           [1 sim,  1 req]
#   Fig 38  — Output Ripple CCM                          [1 sim,  4 reqs]
#   Fig 39  — Output Ripple DCM                          [1 sim,  1 req]
#   Fig 40  — Output Ripple PSM                          [1 sim,  1 req]
#   Fig 41  — Input Ripple CCM                           [1 sim,  1 req]
#   Fig 42  — Input Ripple DCM                           [1 sim,  1 req]
#   Fig 43  — Low Dropout Operation                      [1 sim,  1 req]
#   Fig 44  — Efficiency vs Load Current (5V)            [6 sweeps, no req*]
#   Fig 45  — Light Load Efficiency (5V)                 [2 sweeps, no req*]
#   Fig 46  — Efficiency vs Load Current (3.3V)          [6 sweeps, no req*]
#   Fig 47  — Light Load Efficiency (3.3V)               [2 sweeps, no req*]
#   Fig 48  — (covered by Fig 44 sweeps)
#   Fig 49  — Overall Loop Frequency Response (Bode)     [1 sim,  1 req]
#   Fig 50  — Regulation vs Load Current                 [1 sweep, 1 req]
#   Fig 51  — Regulation vs Input Voltage                [1 sweep, 1 req]
#   Figs 52–55 — Safe Operating Area (thermal) — not simulatable
#
#   * Efficiency cannot be validated with behavioral model (ideal switches)
#
# Netlist element map (from generated circuit.spice):
#   V1 = input voltage source (VIN)
#   R1 = r_bottom (FB divider, 10.2k)
#   R2 = r_comp (compensation, 16.9k)
#   R3 = r_en (EN divider top, 442k)
#   R4 = r_en_bot (EN divider bottom, 90.9k)
#   R5 = r_load (1 ohm)
#   R6 = r_rt (RT/CLK, 243k)
#   R7 = r_top (FB divider, 53.6k)
#   C1 = c_boot (100n)
#   C2 = c_comp (4.7n)
#   C3 = c_comp1 (47p)
#   C4 = c_in (10u)
#   C5-C7 = c_out (3x 47u)
#   L1 = inductor (6.8u)
#
# X1 pin order (TPS54560_TRANS subcircuit):
#   BOOT COMP EN GND SW RT VIN FB
#
# Common extra_spice to override X1 with FS=400k:
#   X1 dut_package_boot dut_package_comp dut_package_en 0
#      dut_package_sw dut_package_rt_clk dut_power_in_hv
#      dut_package_fb TPS54560_TRANS FS=400k
#
# 3.3V FB divider override (for Figs 46, 47):
#   Remove R7 (53.6k), add R_TOP_33 (31.6k) → Vout = 0.8*(31.6k+10.2k)/10.2k ≈ 3.28V
#   Remove R3, R4 (EN divider), force EN high — needed for VIN=6V (below UVLO)
# =============================================================================

module ModelValidation:
    "TPS54560 model validation — DS Section 8.2.3 Application Curves."

    dut = new TI_TPS54560
    assert dut.power_out.voltage within 5V +/- 5%
    assert dut.power_in.voltage within 12V to 48V
    assert dut.power_out.current <= 5A
    assert dut.frequency <= 1MHz

    # =================================================================
    # SIMULATIONS
    # =================================================================

    # -----------------------------------------------------------------
    # 1. STARTUP (DS Figures 36, 37)
    # -----------------------------------------------------------------

    # Fig 36: Start-up with VIN ramp (0 -> 12V)
    # DS scope: VIN (4V/div), VOUT (1V/div), time=2ms/div
    # Captures full startup from t=0 to t=20ms (8000 cycles)
    fig36_startup_vin = new SimulationTransient
    fig36_startup_vin.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig36_startup_vin.time_stop = 20e-3
    fig36_startup_vin.time_step = 1e-6
    fig36_startup_vin.remove_elements = "X1"
    fig36_startup_vin.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k"

    # Fig 37: Start-up with EN control (VIN=12V steady, EN pulse at 2ms)
    # DS scope: VIN (4V/div), EN (2V/div), VOUT (5V/div), time=2ms/div
    fig37_startup_en = new SimulationTransient
    fig37_startup_en.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig37_startup_en.time_stop = 20e-3
    fig37_startup_en.time_step = 1e-6
    fig37_startup_en.remove_elements = "X1,R3"
    fig37_startup_en.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_EN dut_package_en 0 PULSE(0 12 2e-3 10u 10u 10 10)"

    # -----------------------------------------------------------------
    # 2. TRANSIENT RESPONSE (DS Figures 34, 35)
    # -----------------------------------------------------------------

    # Fig 34: Load transient — 1.25A to 3.75A step
    # DS scope: IOUT (1A/div), VOUT AC-coupled (200mV/div), time=100us/div
    # DS Table 1: delta_VOUT = 4% (200mV at 5V)
    # Steady-state from 10ms, step at 15ms, observe 5ms after
    fig34_load_transient = new SimulationTransient
    fig34_load_transient.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig34_load_transient.time_start = 10e-3
    fig34_load_transient.time_stop = 20e-3
    fig34_load_transient.time_step = 500e-9
    fig34_load_transient.remove_elements = "X1,R5"
    fig34_load_transient.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_BASE dut_power_out_hv 0 4|V_ISENSE load_sense 0 0|I_LOAD dut_power_out_hv load_sense PULSE(0 2.5 15e-3 1u 1u 10 10)"

    # Fig 35: Line transient — VIN step 8V to 40V
    # DS scope: VIN (10V/div), VOUT AC-coupled (10mV/div), time=4ms/div
    fig35_line_transient = new SimulationTransient
    fig35_line_transient.spice = "V1 dut_power_in_hv 0 PULSE(8 40 15e-3 1u 1u 5e-3 20e-3)"
    fig35_line_transient.time_start = 8e-3
    fig35_line_transient.time_stop = 30e-3
    fig35_line_transient.time_step = 1e-6
    fig35_line_transient.remove_elements = "X1"
    fig35_line_transient.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k"

    # -----------------------------------------------------------------
    # 3. OUTPUT RIPPLE (DS Figures 38, 39, 40)
    # At 400kHz, T=2.5us. Capture 40 cycles = 100us for robust p-p measurement.
    # -----------------------------------------------------------------

    # Fig 38: Output ripple, CCM (5A load)
    # DS scope: SW (10V/div), IL (1A/div), VOUT AC (10mV/div), time=4us/div
    fig38_ripple_ccm = new SimulationTransient
    fig38_ripple_ccm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig38_ripple_ccm.time_start = 10e-3
    fig38_ripple_ccm.time_stop = 10.1e-3
    fig38_ripple_ccm.time_step = 25e-9
    fig38_ripple_ccm.remove_elements = "X1"
    fig38_ripple_ccm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k"

    # Fig 39: Output ripple, DCM (IOUT=100mA, R=50 ohm)
    # DS scope: SW (10V/div), IL (500mA/div), VOUT AC (10mV/div), time=4us/div
    # DCM needs more settling time (20ms)
    fig39_ripple_dcm = new SimulationTransient
    fig39_ripple_dcm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig39_ripple_dcm.time_start = 20e-3
    fig39_ripple_dcm.time_stop = 20.1e-3
    fig39_ripple_dcm.time_step = 25e-9
    fig39_ripple_dcm.remove_elements = "X1,R5"
    fig39_ripple_dcm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_DCM dut_power_out_hv 0 50"

    # Fig 40: Output ripple, eco-mode / PSM (no load, 100k dummy)
    # DS scope: SW (10V/div), IL (1mA/div), VOUT AC (200mV/div), time=1ms/div
    # PSM has very slow pulse-skipping dynamics — need long window
    fig40_ripple_psm = new SimulationTransient
    fig40_ripple_psm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig40_ripple_psm.time_start = 10e-3
    fig40_ripple_psm.time_stop = 20e-3
    fig40_ripple_psm.time_step = 100e-9
    fig40_ripple_psm.remove_elements = "X1,R5"
    fig40_ripple_psm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_PSM dut_power_out_hv 0 100k"

    # -----------------------------------------------------------------
    # 4. INPUT RIPPLE (DS Figures 41, 42)
    # Same 40-cycle window as output ripple
    # -----------------------------------------------------------------

    # Fig 41: Input ripple, CCM (5A load)
    # DS scope: SW (10V/div), IL (200mA/div), VIN AC (10mV/div), time=4us/div
    fig41_input_ripple_ccm = new SimulationTransient
    fig41_input_ripple_ccm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig41_input_ripple_ccm.time_start = 10e-3
    fig41_input_ripple_ccm.time_stop = 10.1e-3
    fig41_input_ripple_ccm.time_step = 25e-9
    fig41_input_ripple_ccm.remove_elements = "X1"
    fig41_input_ripple_ccm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k"

    # Fig 42: Input ripple, DCM (IOUT=100mA, R=50 ohm)
    # DS scope: SW (10V/div), IL (500mA/div), VIN AC (20mV/div), time=4us/div
    fig42_input_ripple_dcm = new SimulationTransient
    fig42_input_ripple_dcm.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig42_input_ripple_dcm.time_start = 20e-3
    fig42_input_ripple_dcm.time_stop = 20.1e-3
    fig42_input_ripple_dcm.time_step = 25e-9
    fig42_input_ripple_dcm.remove_elements = "X1,R5"
    fig42_input_ripple_dcm.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_LOAD_DCM dut_power_out_hv 0 50"

    # -----------------------------------------------------------------
    # 5. LOW DROPOUT (DS Figure 43)
    # VIN close to VOUT — near 100% duty cycle
    # DS scope: SW (20mV/div), VOUT (2V/div), IL (200mA/div), time=40us/div
    # VIN=7V with 5V output → low headroom (D ≈ 0.71)
    # DS minimum VIN = 7V for 5V output
    # -----------------------------------------------------------------

    fig43_low_dropout = new SimulationTransient
    fig43_low_dropout.spice = "V1 dut_power_in_hv 0 PULSE(0 7 0 10u 10u 10 10)"
    fig43_low_dropout.time_start = 10e-3
    fig43_low_dropout.time_stop = 10.5e-3
    fig43_low_dropout.time_step = 25e-9
    fig43_low_dropout.remove_elements = "X1,R3,R4"
    fig43_low_dropout.extra_spice = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_EN_FORCE dut_package_en 0 DC 5"

    # -----------------------------------------------------------------
    # 6. EFFICIENCY vs LOAD CURRENT — 5V (DS Figure 44)
    # Sweep ILOAD at each VIN: 7, 12, 24, 36, 48, 60V
    # VOUT=5V, fsw=400kHz
    # Note: Behavioral model does not accurately model power loss.
    #       These sweeps produce waveform data but no pass/fail requirements.
    # -----------------------------------------------------------------

    fig44_eff_vin7 = new SimulationSweep
    fig44_eff_vin7.param_name = "ILOAD"
    fig44_eff_vin7.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin7.param_unit = "A"
    fig44_eff_vin7.spice = "V1 dut_power_in_hv 0 PULSE(0 7 0 10u 10u 10 10)"
    fig44_eff_vin7.time_start = 10e-3
    fig44_eff_vin7.time_stop = 10.5e-3
    fig44_eff_vin7.time_step = 500e-9
    fig44_eff_vin7.remove_elements = "X1,R5"
    fig44_eff_vin7.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig44_eff_vin12 = new SimulationSweep
    fig44_eff_vin12.param_name = "ILOAD"
    fig44_eff_vin12.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin12.param_unit = "A"
    fig44_eff_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig44_eff_vin12.time_start = 10e-3
    fig44_eff_vin12.time_stop = 10.5e-3
    fig44_eff_vin12.time_step = 500e-9
    fig44_eff_vin12.remove_elements = "X1,R5"
    fig44_eff_vin12.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig44_eff_vin24 = new SimulationSweep
    fig44_eff_vin24.param_name = "ILOAD"
    fig44_eff_vin24.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin24.param_unit = "A"
    fig44_eff_vin24.spice = "V1 dut_power_in_hv 0 PULSE(0 24 0 10u 10u 10 10)"
    fig44_eff_vin24.time_start = 10e-3
    fig44_eff_vin24.time_stop = 10.5e-3
    fig44_eff_vin24.time_step = 500e-9
    fig44_eff_vin24.remove_elements = "X1,R5"
    fig44_eff_vin24.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig44_eff_vin36 = new SimulationSweep
    fig44_eff_vin36.param_name = "ILOAD"
    fig44_eff_vin36.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin36.param_unit = "A"
    fig44_eff_vin36.spice = "V1 dut_power_in_hv 0 PULSE(0 36 0 10u 10u 10 10)"
    fig44_eff_vin36.time_start = 10e-3
    fig44_eff_vin36.time_stop = 10.5e-3
    fig44_eff_vin36.time_step = 500e-9
    fig44_eff_vin36.remove_elements = "X1,R5"
    fig44_eff_vin36.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig44_eff_vin48 = new SimulationSweep
    fig44_eff_vin48.param_name = "ILOAD"
    fig44_eff_vin48.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin48.param_unit = "A"
    fig44_eff_vin48.spice = "V1 dut_power_in_hv 0 PULSE(0 48 0 10u 10u 10 10)"
    fig44_eff_vin48.time_start = 10e-3
    fig44_eff_vin48.time_stop = 10.5e-3
    fig44_eff_vin48.time_step = 500e-9
    fig44_eff_vin48.remove_elements = "X1,R5"
    fig44_eff_vin48.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig44_eff_vin60 = new SimulationSweep
    fig44_eff_vin60.param_name = "ILOAD"
    fig44_eff_vin60.param_values = "0.5,1,2,3,4,5"
    fig44_eff_vin60.param_unit = "A"
    fig44_eff_vin60.spice = "V1 dut_power_in_hv 0 PULSE(0 60 0 10u 10u 10 10)"
    fig44_eff_vin60.time_start = 10e-3
    fig44_eff_vin60.time_stop = 10.5e-3
    fig44_eff_vin60.time_step = 500e-9
    fig44_eff_vin60.remove_elements = "X1,R5"
    fig44_eff_vin60.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    # -----------------------------------------------------------------
    # 7. LIGHT LOAD EFFICIENCY — 5V (DS Figure 45)
    # Log-scale current sweep: 1mA to 1A
    # -----------------------------------------------------------------

    fig45_light_eff_vin12 = new SimulationSweep
    fig45_light_eff_vin12.param_name = "ILOAD"
    fig45_light_eff_vin12.param_values = "0.001,0.005,0.01,0.05,0.1,0.5,1"
    fig45_light_eff_vin12.param_unit = "A"
    fig45_light_eff_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig45_light_eff_vin12.time_start = 20e-3
    fig45_light_eff_vin12.time_stop = 21e-3
    fig45_light_eff_vin12.time_step = 500e-9
    fig45_light_eff_vin12.remove_elements = "X1,R5"
    fig45_light_eff_vin12.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig45_light_eff_vin48 = new SimulationSweep
    fig45_light_eff_vin48.param_name = "ILOAD"
    fig45_light_eff_vin48.param_values = "0.001,0.005,0.01,0.05,0.1,0.5,1"
    fig45_light_eff_vin48.param_unit = "A"
    fig45_light_eff_vin48.spice = "V1 dut_power_in_hv 0 PULSE(0 48 0 10u 10u 10 10)"
    fig45_light_eff_vin48.time_start = 20e-3
    fig45_light_eff_vin48.time_stop = 21e-3
    fig45_light_eff_vin48.time_step = 500e-9
    fig45_light_eff_vin48.remove_elements = "X1,R5"
    fig45_light_eff_vin48.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    # -----------------------------------------------------------------
    # 8. EFFICIENCY vs LOAD CURRENT — 3.3V (DS Figure 46)
    # Same as Fig 44 but with 3.3V FB divider: R7→31.6k (R1=10.2k stays)
    # Vout = 0.8 * (31.6k + 10.2k) / 10.2k ≈ 3.28V
    # EN divider removed and forced high for VIN=6V operation
    # VIN sweep: 6, 12, 24, 36, 48, 60V
    # -----------------------------------------------------------------

    fig46_eff_3v3_vin6 = new SimulationSweep
    fig46_eff_3v3_vin6.param_name = "ILOAD"
    fig46_eff_3v3_vin6.param_values = "0.5,1,2,3,4,5"
    fig46_eff_3v3_vin6.param_unit = "A"
    fig46_eff_3v3_vin6.spice = "V1 dut_power_in_hv 0 PULSE(0 6 0 10u 10u 10 10)"
    fig46_eff_3v3_vin6.time_start = 10e-3
    fig46_eff_3v3_vin6.time_stop = 10.5e-3
    fig46_eff_3v3_vin6.time_step = 500e-9
    fig46_eff_3v3_vin6.remove_elements = "X1,R5,R7,R3,R4"
    fig46_eff_3v3_vin6.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_TOP_33 dut_power_out_hv dut_package_5 31.6k|V_EN_FORCE dut_package_en 0 DC 5|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig46_eff_3v3_vin12 = new SimulationSweep
    fig46_eff_3v3_vin12.param_name = "ILOAD"
    fig46_eff_3v3_vin12.param_values = "0.5,1,2,3,4,5"
    fig46_eff_3v3_vin12.param_unit = "A"
    fig46_eff_3v3_vin12.spice = "V1 dut_power_in_hv 0 PULSE(0 12 0 10u 10u 10 10)"
    fig46_eff_3v3_vin12.time_start = 10e-3
    fig46_eff_3v3_vin12.time_stop = 10.5e-3
    fig46_eff_3v3_vin12.time_step = 500e-9
    fig46_eff_3v3_vin12.remove_elements = "X1,R5,R7,R3,R4"
    fig46_eff_3v3_vin12.extra_spice_template = "X1 dut_package_boot dut_package_comp dut_package_en 0 dut_package_sw dut_package_rt_clk dut_power_in_hv dut_package_fb TPS54560_TRANS FS=400k|R_TOP_33 dut_power_out_hv dut_package_5 31.6k|V_EN_FORCE dut_package_en 0 DC 5|V_LSENSE dut_power_out_hv lsense_node 0|I_LOAD lsense_node 0 DC {ILOAD}"

    fig46_eff_3v3_vin24 = new SimulationSweep
    fig46_eff_3v3_vin24.param_name = "ILOAD"
    fig46_eff_3v3_vin24.param_values = "0.5,1,2,3,4,5"
    fig46_eff_3v3_vin24.param_unit = "A"
