#pragma experiment("TRAITS")
#pragma experiment("FOR_LOOP")

import ElectricPower
import ElectricLogic
import DifferentialPair
import USB2_0
import UART
import Resistor
import Capacitor
import Inductor
import Diode
import Fuse
import RectangularBoardShape
import MountingHole
import has_requirement
from "parts/Texas_Instruments_TCAN332GDR/Texas_Instruments_TCAN332GDR.ato" import Texas_Instruments_TCAN332GDR_package
from "atopile/st-stm32h723/st-stm32h723.ato" import ST_STM32H723
from "atopile/microchip-lan8742a/microchip-lan8742a.ato" import Microchip_LAN8742A
from "atopile/usb-connectors/usb-connectors.ato" import USB2_0TypeCHorizontalConnector
from "atopile/xt-connectors/xt-connectors.ato" import XT30_Male_Right_Angle

module BLDCMotorController:
    """
    Industrial BLDC motor controller implementation.

    40V nominal input front-end, discrete regulator stages, 3-phase gate/power stages,
    MCU control domain, and communications + external I/O interfaces.
    """

    trait has_requirement<id="R1", text="MCU platform", criteria="Uses STM32H-class control subsystem interface set">
    trait has_requirement<id="R2", text="Power and current capability", criteria="Input domain includes 40V operation and power stage targets 20A continuous current">
    trait has_requirement<id="R3", text="Industrial communications", criteria="Includes USB setup/programming plus CAN FD and Ethernet interfaces">
    trait has_requirement<id="R4", text="Mechanical envelope", criteria="Board outline is 40mm x 60mm compact format with M3 mounting holes">
    trait has_requirement<id="R5", text="Power and motor I/O", criteria="Includes power input and three motor phase outputs">

    board = new BoardMechanical
    power_frontend = new PowerFrontend
    control = new ControlSubsystem
    gate_driver = new GateDriverStage
    power_stage = new PowerStage
    comms = new CommunicationsSubsystem
    io = new IOModule

    power_frontend.power_40v ~ io.power_in
    power_frontend.power_40v ~ gate_driver.bus_power
    power_frontend.power_40v ~ power_stage.bus_power

    power_frontend.rail_12v ~ gate_driver.gate_supply
    power_frontend.rail_3v3 ~ control.power_3v3
    power_frontend.rail_3v3 ~ comms.logic_power

    control.pwm_abc ~ gate_driver.pwm_abc
    gate_driver.gate_abc ~ power_stage.gate_abc
    power_stage.phase_abc ~ io.phase_abc

    control.can_fd ~ comms.can_fd
    control.ethernet_mii ~ comms.ethernet_mii
    control.usb_setup ~ io.usb_setup

    for hole in board.mounting_holes:
        hole.contact ~ power_frontend.power_40v.lv

module BoardMechanical:
    """Board outline and mechanical mounting pattern."""
    trait has_requirement<id="R4", text="Compact board", criteria="Rectangular 40mm x 60mm board with rounded corners and 4x M3 mounting holes">

    outline = new RectangularBoardShape
    outline.width = 40mm
    outline.height = 60mm
    outline.corner_radius = 2mm
    outline.mounting_hole_diameter = 3.2mm

    mounting_holes = new MountingHole[4]


module FixedBuckRegulator:
    """Discrete buck regulator skeleton with fixed feedback resistors."""

    power_in = new ElectricPower
    power_out = new ElectricPower
    enable = new ElectricLogic

    switch_node = new ElectricPower

    input_fuse = new Fuse
    catch_diode = new Diode
    out_inductor = new Inductor
    cin_bulk = new Capacitor
    cout_bulk = new Capacitor
    cff = new Capacitor

    r_fb_top = new Resistor
    r_fb_bottom = new Resistor

    power_in.hv ~ input_fuse.unnamed[0]
    power_in.hv ~ cin_bulk.unnamed[0]
    power_in.lv ~ cin_bulk.unnamed[1]

    input_fuse.unnamed[1] ~ switch_node.hv
    switch_node.hv ~ catch_diode.anode
    catch_diode.cathode ~ power_in.lv

    switch_node.hv ~ out_inductor.unnamed[0]
    out_inductor.unnamed[1] ~ power_out.hv
    power_out.lv ~ power_in.lv

    power_out.hv ~ cout_bulk.unnamed[0]
    power_out.lv ~ cout_bulk.unnamed[1]

    r_fb_top.unnamed[0] ~ power_out.hv
    r_fb_top.unnamed[1] ~ cff.unnamed[0]
    cff.unnamed[1] ~ r_fb_bottom.unnamed[0]
    r_fb_bottom.unnamed[1] ~ power_out.lv

    enable.reference ~ power_in
    enable.reference ~ power_out

    assert power_in.voltage within 8V to 40V
    assert power_out.voltage within 3V to 15V

    input_fuse.trip_current = 4A +/- 25%
    cin_bulk.capacitance = 22uF +/- 20%
    cout_bulk.capacitance = 47uF +/- 20%
    cff.capacitance = 2.2nF +/- 10%

    out_inductor.inductance = 22uH +/- 20%

    r_fb_top.resistance = 56kohm +/- 1%
    r_fb_bottom.resistance = 6.49kohm +/- 1%

module FixedLDORegulator:
    """Linear post-regulator with fixed feedback resistors (no helper divider module)."""

    power_in = new ElectricPower
    power_out = new ElectricPower
    enable = new ElectricLogic

    cin = new Capacitor
    cout = new Capacitor
    r_fb_top = new Resistor
    r_fb_bottom = new Resistor

    power_in.hv ~ cin.unnamed[0]
    power_in.lv ~ cin.unnamed[1]

    power_out.hv ~ cout.unnamed[0]
    power_out.lv ~ cout.unnamed[1]
    power_out.lv ~ power_in.lv

    r_fb_top.unnamed[0] ~ power_out.hv
    r_fb_top.unnamed[1] ~ r_fb_bottom.unnamed[0]
    r_fb_bottom.unnamed[1] ~ power_out.lv

    enable.reference ~ power_in
    enable.reference ~ power_out

    assert power_in.voltage within 4.5V to 14V
    assert power_out.voltage within 3.3V +/- 3%

    cin.capacitance = 4.7uF +/- 20%
    cout.capacitance = 10uF +/- 20%
    r_fb_top.resistance = 20kohm +/- 1%
    r_fb_bottom.resistance = 10kohm +/- 1%

module PowerFrontend:
    """Input filtering/protection plus discrete 12V and 3V3 regulator chain."""
    trait has_requirement<id="R2", text="40V input rating", criteria="Input rail constrained for 36V to 40V operation">

    power_40v = new ElectricPower
    rail_12v = new ElectricPower
    rail_3v3 = new ElectricPower

    reverse_protection_diode = new Diode
    input_bulk = new Capacitor

    buck_12v = new FixedBuckRegulator
    ldo_3v3 = new FixedLDORegulator

    power_40v.hv ~ reverse_protection_diode.anode
    reverse_protection_diode.cathode ~ buck_12v.power_in.hv
    power_40v.lv ~ buck_12v.power_in.lv

    buck_12v.power_out ~ rail_12v
    rail_12v ~ ldo_3v3.power_in
    ldo_3v3.power_out ~ rail_3v3

    power_40v.hv ~ input_bulk.unnamed[0]
    power_40v.lv ~ input_bulk.unnamed[1]

    assert power_40v.voltage within 36V to 40V
    assert rail_12v.voltage within 12V +/- 5%
module ControlSubsystem:
    """STM32H-series MCU control and high-level motor/comms interfaces."""
    trait has_requirement<id="R1", text="STM32H controller", criteria="Control subsystem implemented around STM32H series MCU">

    power_3v3 = new ElectricPower
    pwm_abc = new DifferentialPair[3]
    can_fd = new DifferentialPair
    ethernet_mii = new UART
    usb_setup = new USB2_0

    mcu = new ST_STM32H723

    power_3v3 ~ mcu.power_3v3
    usb_setup ~ mcu.usb

    pwm_abc[0].p ~ mcu.gpio_a[8]
    pwm_abc[1].p ~ mcu.gpio_a[9]
    pwm_abc[2].p ~ mcu.gpio_a[10]

    pwm_abc[0].p.reference ~ power_3v3
    pwm_abc[0].n.reference ~ power_3v3
    pwm_abc[1].p.reference ~ power_3v3
    pwm_abc[1].n.reference ~ power_3v3
    pwm_abc[2].p.reference ~ power_3v3
    pwm_abc[2].n.reference ~ power_3v3

    can_fd.p ~ mcu.uart.base_uart.tx
    can_fd.n ~ mcu.uart.base_uart.rx

    ethernet_mii.base_uart.tx ~ mcu.mdio.mdc
    ethernet_mii.base_uart.rx ~ mcu.mdio.mdio

    assert power_3v3.voltage within 3.3V +/- 5%

module GateDriverStage:
    """DRV8300 gate-driver stage linking MCU PWM outputs to power MOSFET gates."""
    trait has_requirement<id="R6", text="Gate driver", criteria="Uses DRV8300 class 3-phase gate driver architecture">

    bus_power = new ElectricPower
    gate_supply = new ElectricPower
    pwm_abc = new DifferentialPair[3]
    gate_abc = new DifferentialPair[3]

    assert bus_power.voltage within 36V to 40V
    assert gate_supply.voltage within 10V to 12V

    pwm_abc[0].p ~ gate_abc[0].p
    pwm_abc[0].n ~ gate_abc[0].n
    pwm_abc[1].p ~ gate_abc[1].p
    pwm_abc[1].n ~ gate_abc[1].n
    pwm_abc[2].p ~ gate_abc[2].p
    pwm_abc[2].n ~ gate_abc[2].n

module PowerStage:
    """Three-phase MOSFET bridge sized for continuous motor current."""
    trait has_requirement<id="R2", text="20A continuous", criteria="Power stage devices and thermal design support >=20A continuous motor current">

    bus_power = new ElectricPower
    gate_abc = new DifferentialPair[3]
    phase_abc = new ElectricPower[3]

    phase_current_continuous: A
    assert phase_current_continuous >= 20A
    assert bus_power.voltage within 36V to 40V

module CommunicationsSubsystem:
    """Industrial comms interfaces: CAN FD and Ethernet PHY to RJ45."""
    trait has_requirement<id="R3", text="CAN FD", criteria="Subsystem includes CAN FD physical interface">
    trait has_requirement<id="R3b", text="Ethernet RJ45", criteria="Subsystem includes Ethernet interface for RJ45 connector communication">

    logic_power = new ElectricPower
    can_fd = new DifferentialPair
    ethernet_mii = new UART

    can_phy = new Texas_Instruments_TCAN332GDR_package
    can_term = new Resistor

    can_term.resistance = 120ohm +/- 1%

    can_fd.p.line ~ can_phy.CANH
    can_fd.n.line ~ can_phy.CANL
    can_fd.p.line ~ can_term.unnamed[0]
    can_fd.n.line ~ can_term.unnamed[1]

    phy = new Microchip_LAN8742A

    logic_power ~ phy.power_3v3
    can_phy.VCC ~ logic_power.hv
    can_phy.GND ~ logic_power.lv
    ethernet_mii.base_uart.tx.line ~ can_phy.TXD
    ethernet_mii.base_uart.rx.line ~ can_phy.RXD
    ethernet_mii.base_uart.tx ~ phy.mdio.mdc
    ethernet_mii.base_uart.rx ~ phy.mdio.mdio

    assert logic_power.voltage within 3.3V +/- 5%

module IOModule:
    """External connectors for power, motor phases, USB setup, and comms exposure."""
    trait has_requirement<id="R5", text="Power input connector", criteria="I/O includes 2-pin power input connector interface">
    trait has_requirement<id="R5b", text="Phase outputs", criteria="Three phase outputs terminate to power output interfaces">
    trait has_requirement<id="R3", text="USB setup/programming", criteria="USB connector present for setup and programming">

    power_in = new ElectricPower
    phase_abc = new ElectricPower[3]
    usb_setup = new USB2_0

    xt30_in = new XT30_Male_Right_Angle
    usb_c = new USB2_0TypeCHorizontalConnector

    power_in ~ xt30_in.power
    usb_setup ~ usb_c.usb
