{
  "name": "atopile",
  "displayName": "atopile",
  "description": "atopile EDA tooling for VS Code",
  "version": "0.0.1",
  "publisher": "atopile",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "ato_logo_256x256.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atopile-sidebar",
          "title": "atopile",
          "icon": "resources/atopile-icon.svg"
        }
      ]
    },
    "views": {
      "atopile-sidebar": [
        {
          "type": "webview",
          "id": "atopile.sidebarView",
          "name": "atopile"
        }
      ]
    },
    "commands": [
      {
        "command": "atopile.openPanel",
        "title": "atopile: Open Panel"
      },
      {
        "command": "atopile.restart",
        "title": "atopile: Restart Core Server"
      }
    ]
  },
  "scripts": {
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd ../ui/webview && bun run build",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "cd ../ui/webview && bun run watch",
    "watch": "concurrently \"bun run watch:extension\" \"bun run watch:webview\"",
    "vscode:prepublish": "bun run build:extension && bun run build:webview",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "concurrently": "^8.2.0",
    "@vscode/vsce": "^2.22.0"
  }
}
