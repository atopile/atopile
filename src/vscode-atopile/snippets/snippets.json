{
	"module": {
		"scope": "ato",
		"prefix": "module",
		"body": [
			"module ${1}:",
			"\t\"\"\"",
			"\t${2}",
			"\t\"\"\"",
			"",
			"\t${3}"
		]
	},
	"component": {
		"scope": "ato",
		"prefix": "component",
		"body": [
			"component ${1}:",
			"\tpin ${2}"
		]
	},
	"resistor": {
		"description": "Resistor common options",
		"scope": "ato",
		"prefix": "resistor",
		"body": [
			"${1} = new Resistor",
			"${1}.resistance = ${2}${3|ohm,kohm|} +/- ${4|1,5,10|}%",
			"${1}.package = \"${5|0402,0603,0805,1206|}\""
		]
	},
	"capacitor": {
		"description": "Capacitor common options",
		"scope": "ato",
		"prefix": "capacitor",
		"body": [
			"${1} = new Capacitor",
			"${1}.capacitance = ${2}${3|pF,nF,uF|} +/- ${4|10,20|}%",
			"assert ${1}.max_voltage >= ${5|6.3,10,16,25,50,100,200|}V",
			"${1}.package = \"${6|0402,0603,0805,1206|}\""
		]
	}
}
