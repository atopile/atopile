{
	"module": {
		"scope": "ato",
		"prefix": "module",
		"body": [
			"module ${1}:",
			"\t\"\"\"",
			"\t${2}",
			"\t\"\"\"",
			"",
			"\t${3}"
		]
	},
	"component": {
		"scope": "ato",
		"prefix": "component",
		"body": [
			"component ${1}:",
			"\tpin ${2}"
		]
	},
	"resistor": {
		"description": "Resistor common options",
		"scope": "ato",
		"prefix": "resistor",
		"body": [
			"${1} = new Resistor",
			"${1}.resistance = ${2}${3|kohm,ohm,mohm|} +/- ${4|5,1,10|}%",
			"${1}.package = \"${5|0402,0201,0603,0805|}\""
		]
	},
	"capacitor": {
		"description": "Capacitor common options",
		"scope": "ato",
		"prefix": "capacitor",
		"body": [
			"${1} = new Capacitor",
			"${1}.capacitance = ${2}${3|nF,pF,uF|} +/- ${4|10,20|}%",
			"assert ${1}.max_voltage >= ${5|16,6,10,25|}V",
			"${1}.package = \"${6|0402,0201,0603,0805,1206|}\""
		]
	}
}
